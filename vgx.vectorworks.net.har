false;\n\t\t}\n\t\t\n\t};\n\n\tthis.updateJoystickDir = function( inActualMoveSpeed ) {\n\t\tvar speeds = null;\n\t\tvar bAdjustSpeeds = false;\n\t\tif (joystickDir != null) {\n\t\t\tif (joystickDir['degree'] < 90.00 && joystickDir['degree'] > 0.00) {\n\t\t\t\tthis.moveForward = true;\n\t\t\t\tthis.moveRight = true;\n\t\t\t\tbAdjustSpeeds = true;\n\t\t\t}\n\t\t\telse if (joystickDir['degree'] < 180.00 && joystickDir['degree'] > 90.00) {\n\t\t\t\tthis.moveForward = true;\n\t\t\t\tthis.moveLeft = true;\n\t\t\t\tbAdjustSpeeds = true;\n\t\t\t}\n\t\t\telse if (joystickDir['degree'] < 270.00 && joystickDir['degree'] > 180.00){\n\t\t\t\tthis.moveBackward = true;\n\t\t\t\tthis.moveLeft = true;\n\t\t\t\tbAdjustSpeeds = true;\n\t\t\t}\n\t\t\telse if (joystickDir['degree'] < 360.00 && joystickDir['degree'] > 270.00){\n\t\t\t\tthis.moveBackward = true;\n\t\t\t\tthis.moveRight = true;\n\t\t\t\tbAdjustSpeeds = true;\n\t\t\t}\n\t\t\telse if (joystickDir['degree'] == 0.00) {\n\t\t\t\tthis.moveRight = true;\n\t\t\t}\n\t\t\telse if (joystickDir['degree'] == 90.00) {\n\t\t\t\tthis.moveForward = true;\n\t\t\t}\n\t\t\telse if (joystickDir['degree'] == 180.00) {\n\t\t\t\tthis.moveLeft = true;\n\t\t\t}\n\t\t\telse if (joystickDir['degree'] == 270.00) {\n\t\t\t\tthis.moveBackward = true;\n\t\t\t}\t\t\t\t\t\t\t\t\t\n\t\t}\n\t\tif (bAdjustSpeeds) {\n\t\t\tspeeds = new THREE.Vector2();\n\t\t\tspeeds.x = inActualMoveSpeed*Math.cos(joystickDir['radian']);\n\t\t\tspeeds.y = inActualMoveSpeed*Math.sin(joystickDir['radian']);\n\t\t}\n\t\treturn speeds;\n\t};\n\n\tthis.updateFirstTimeVisit = function(){\n\t\tif (bFirstTimeVisitingFP) {\n\t\t\tboxTarget2.style.display = 'none';\n\t\t\tbFirstTimeVisitingFP = false;\n\t\t}\n\t};\n\n\t// Begin_Review need to set original yPos if Walk through walls is on to prevent flying into space.\n\tthis.setWalkToOriginalY = function(yPos){\n\t\tif (bIsCollisionOn)\n\t\t\tthis.object.position.y = yPos;\n\t};\n\t\n\tthis.update = function(  ) {\n\n\t\tif ( this.enabl