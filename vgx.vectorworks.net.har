o)|s55\\/|sa(ge|ma|mm|ms|ny|va)|sc(01|h\\-|oo|p\\-)|sdk\\/|se(c(\\-|0|1)|47|mc|nd|ri)|sgh\\-|shar|sie(\\-|m)|sk\\-0|sl(45|id)|sm(al|ar|b3|it|t5)|so(ft|ny)|sp(01|h\\-|v\\-|v )|sy(01|mb)|t2(18|50)|t6(00|10|18)|ta(gt|lk)|tcl\\-|tdg\\-|tel(i|m)|tim\\-|t\\-mo|to(pl|sh)|ts(70|m\\-|m3|m5)|tx\\-9|up(\\.b|g1|si)|utst|v400|v750|veri|vi(rg|te)|vk(40|5[0-3]|\\-v)|vm40|voda|vulc|vx(52|53|60|61|70|80|81|83|85|98)|w3c(\\-| )|webc|whit|wi(g |nc|nw)|wmlb|wonu|x700|yas\\-|your|zeto|zte\\-/i.test(a.substr(0, 4)))\n            check = true\n    })(navigator.userAgent || navigator.vendor || window.opera);\n    */\n    return check;\n}\n\n// Written by AGorbaty\n\nfunction CloseTutorial() {\n\tif (boxTarget !== undefined)\n\t\tboxTarget.style.display = 'none';\n\tif (boxTarget2 !== undefined)\n\t\tboxTarget2.style.display = 'none';\n\tbFirstTimeVisitingFP = false;\n\tbFirstTimeVisitingStereo = false;\n}\n\nfunction DoTutorial() {\n\tboxTarget = document.getElementById('startupTutorial');\n\tboxTargetTxt = document.getElementById('startupTutorialPrmpt');\n\tif (mobileAndTabletcheck())\n\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_2\"];\n\telse\n\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_3\"];\n\tboxTarget2 = document.getElementById('contextualTutorial');\n\tboxTarget2Txt = document.getElementById('contextualTutorialPrmpt');\n\tif(mobileAndTabletcheck())\n\t\tboxTarget2Txt.innerHTML = resources[\"#tut_mes_14\"];\n\telse\n\t\tboxTarget2Txt.innerHTML = resources[\"#tut_mes_13\"];\n\tvar xComp = window.innerWidth;\n\tvar yComp = window.innerHeight;\n\t/*\n\tif (mobileAndTabletcheck() && window.orientation % 180 != 0) { // if in landscape\n\t\txComp = window.innerHeight;\n\t\tyComp = window.innerWidth;\n\t}\n\t*/\n\n\tvar decodedCookie = decodeURIComponent(document.cookie);\n\tif (decodedCookie == \"\") {\n\t\tbFirstTimeVisitingFP = true;\n\t\tbFirstTimeVisitingStereo = true;\n\t\tboxTarget.style.display = 'block';\n\t\tdocument.cookie = \"username=default; path=/\";\n\t}\n\telse{\n\t\tboxTarget.style.display = 'none';\n\t\tboxTarget2.style.display = 'none';\n\t}\n\n\t$(\"#closePrmpt\").css({ \"display\": \"block\" });\n\n\tboxPos = {x: window.innerWidth/2, y: window.innerHeight/2, rotation: 0};\n\t// first movement\n\tfirstTween = new TWEEN.Tween(boxPos)\n\t\t.to({x: xComp/2, y: (yComp/2) - 50, rotation: 0}, 2000)\n\t\t.easing(TWEEN.Easing.Elastic.InOut);\n\n\t// second movement\n\tsecondTween = new TWEEN.Tween(boxPos)\n\t\t.to({x: xComp-200, y: yComp-200, rotation: 0}, 2000)\n\t\t.easing(TWEEN.Easing.Elastic.InOut);\n\n\t// third movement\n\tthirdTween = new TWEEN.Tween(boxPos)\n\t\t.to({x: xComp-200, y: 100, rotation: 0}, 2000)\n\t\t.easing(TWEEN.Easing.Elastic.InOut);\n\n\t// fourth movement\n\tfourTween = new TWEEN.Tween(boxPos)\n\t\t.to({x: 50, y: yComp-200, rotation: 0}, 2000)\n\t\t.easing(TWEEN.Easing.Elastic.InOut);\n\n\tcontextTween = new TWEEN.Tween(boxPos)\n\t\t.to({x: xComp/3, y: (yComp/3), rotation: 0}, 500)\n\t\t.easing(TWEEN.Easing.Elastic.InOut);\n\n\tcurrTween = firstTween;\n\n\tcurrTween.start();\n}\n\n /*\n    This method switches the clip cube button and its some of its attributes (visibility, etc.).\n\n    config parameters:\n    isCCOn - force the interactive clip planes to be on/off.\n    isBtnVis - force the interactive CC button to be visible/invisible.\n    doReset - reset the clipping planes within the model.\n */\n function switchInteractiveClipCube(config) {\n    if (manager._clipSimulation !== undefined){\n        interactiveCCSwitch = config !== undefined ? config.isCCOn : !interactiveCCSwitch;\n        var cubeOffImgUrl = window.Configuration.withStaticPrefix('cubeOff.png');\n        var cubeOnImgUrl = window.Configuration.withStaticPrefix('cubeOn.png');\n        var img = interactiveCCSwitch ? \"transparent url(\" + cubeOnImgUrl + \")\" : \"transparent url(\" + cubeOffImgUrl + \" )\";\n        $(\"#clipCubeBtn\").css({\"background\" : img});\n        manager._clipSimulation.setSelectionMeshVisibility(interactiveCCSwitch);\n    }\n\n    if (config !== undefined){\n        var btnVisStr = config.isBtnVis !== undefined && config.isBtnVis === true ? \"inline\" : \"none\";\n        $(\"#clipCubeBtn\").css({\"display\" : btnVisStr}); // make button visible/invisible\n        if (config.doReset)\n            manager._clipSimulation.resetPlanes();\n    }\n}\n\nfunction fpcDis() {\n    bAreFPCen = controlsFRC.enabled;\n    if (bAreFPCen) {\n        controlsFRC.enabled = false;\n        document.addEventListener(\"mouseup\", fpcEn);\n        document.addEventListener(\"touchend\", fpcEn);\n    }\n}\n\nfunction fpcEn() {\n    if (bAreFPCen) {\n        controlsFRC.enabled = true;\n        bAreFPCen = false;\n        document.removeEventListener(\"mouseup\", fpcEn);\n        document.removeEventListener(\"touchend\", fpcEn);\n    }\n}\n\nfunction replaceWithImgStr(inMainStr, inDelimiter, inImgStr){\n\tvar outStr = inMainStr.replace(inDelimiter, inImgStr);\n\treturn outStr;\n}\n\nfunction setMetricSetting () {\n    var IsInMetricStr = resources[\"#Other Options App\"][\"FP Settings\"][\"isMetric\"];\n    if (IsInMetricStr && IsInMetricStr.indexOf(\"true\") > -1)\n        bIsInMetric = true;\n    else\n        bIsInMetric = false;\n}\n\nfunction setWebAppStrings() {\n    var othTab = document.getElementById(\"camcontrol\");\n    othTab.title = resources[\"#tooltips\"][\"view\"];\n    othTab = document.getElementById(\"DefViewType\");\n    othTab.title = resources[\"#tooltips\"][\"other\"];\n    othTab = document.getElementById(\"resetButtonImg\");\n    othTab.title = resources[\"#tooltips\"][\"home\"];\n    othTab = document.getElementById(\"view360menubutton\");\n    othTab.title = resources[\"#tooltips\"][\"stereo\"];\n    othTab = document.getElementById(\"helpbtn\");\n    othTab.title = resources['#Viewing Controls App']['help'];\n    $(\"#walkSpeedText\").text(resources[\"#360 Controls App\"][\"walk\"] + stereoSpeedScale.toString());\n    $(\"#walkSpeedText1\").text(resources[\"#