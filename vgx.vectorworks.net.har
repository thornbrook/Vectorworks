          "content": {
            "size": 28894,
            "mimeType": "binary/octet-stream",
            "compression": 0,
            "text": "var resources = {\"#Viewing Controls App\" : {\"orbit\" : \"\\u0026\\u006e\\u0062\\u0073\\u0070\\u0020\\u004f\\u0072\\u0062\\u0069\\u0074\\u0020\\u0043\\u006f\\u006e\\u0074\\u0072\\u006f\\u006c\",\"first\" : \"\\u0026\\u006e\\u0062\\u0073\\u0070\\u0020\\u0046\\u0069\\u0072\\u0073\\u0074\\u0020\\u0050\\u0065\\u0072\\u0073\\u006f\\u006e\",\"help\" : \"\\u0048\\u0065\\u006c\\u0070\"}, \"#360 Controls App\" : {\"mono\" : \"\\u0026\\u006e\\u0062\\u0073\\u0070\\u0020\\u004d\\u006f\\u006e\\u006f\\u0020\\u004d\\u006f\\u0064\\u0065\",\"stereo\" : \"\\u0026\\u006e\\u0062\\u0073\\u0070\\u0020\\u0053\\u0074\\u0065\\u0072\\u0065\\u006f\\u0020\\u0056\\u0069\\u0065\\u0077\",\"help\" : \"\\u0048\\u0065\\u006c\\u0070\",\"walk\" : \"\\u0057\\u0061\\u006c\\u006b\\u0020\\u0053\\u0070\\u0065\\u0065\\u0064\\u003a\\u0020\"}, \"#Other Options App\" : {\"Views\" : {\"top\" : \"\",\"fro\" : \"\",\"bac\" : \"\",\"rig\" : \"\",\"lef\" : \"\",\"bot\" : \"\",\"def\" : \"\"}, \"FP Settings\" : {\"sh\" : \"\",\"feet\" : \"\",\"inches\" : \"\",\"meters\" : \"\",\"centimeters\" : \"\",\"walkThru\" : \"\\u0057\\u0061\\u006c\\u006b\\u0020\\u0054\\u0068\\u0072\\u006f\\u0075\\u0067\\u0068\\u0020\\u0057\\u0061\\u006c\\u006c\\u0073\",\"walkSpeed\" : \"\\u0057\\u0061\\u006c\\u006b\\u0069\\u006e\\u0067\\u0020\\u0053\\u0070\\u0065\\u0065\\u0064\",\"rotSense\" : \"\\u0052\\u006f\\u0074\\u0061\\u0074\\u0065\\u0020\\u0053\\u0065\\u006e\\u0073\\u0069\\u0074\\u0069\\u0076\\u0069\\u0074\\u0079\",\"isMetric\" : \"true\",\"def\" : \"\\u0046\\u0069\\u0072\\u0073\\u0074\\u0020\\u0050\\u0065\\u0072\\u0073\\u006f\\u006e\\u0020\\u004f\\u0070\\u0074\\u0069\\u006f\\u006e\\u0073\"}, \"Shadow Settings\" : {\"shadowOptionsStr\" : \"\\u0053\\u0068\\u0061\\u0064\\u006f\\u0077\\u0020\\u004f\\u0070\\u0074\\u0069\\u006f\\u006e\\u0073\",\"displayShadowsStr\" : \"\\u0044\\u0069\\u0073\\u0070\\u006c\\u0061\\u0079\\u0020\\u0053\\u0068\\u0061\\u0064\\u006f\\u0077\\u0073\",\"lightDirStr\" : \"\\u004c\\u0069\\u0067\\u0068\\u0074\\u0020\\u0044\\u0069\\u0072\\u0065\\u0063\\u0074\\u0069\\u006f\\u006e\"} }, \"#tooltips\" : {\"view\" : \"\\u0053\\u0065\\u006c\\u0065\\u0063\\u0074\\u0020\\u0043\\u0061\\u006d\\u0065\\u0072\\u0061\\u0020\\u0043\\u006f\\u006e\\u0074\\u0072\\u006f\\u006c\\u006c\\u0065\\u0072\",\"orbit\" : \"\\u004f\\u0072\\u0062\\u0069\\u0074\\u0020\\u0043\\u006f\\u006e\\u0074\\u0072\\u006f\\u006c\\u0020\\u004d\\u006f\\u0064\\u0065\",\"first\" : \"\\u0046\\u0069\\u0072\\u0073\\u0074\\u0020\\u0050\\u0065\\u0072\\u0073\\u006f\\u006e\\u0020\\u0043\\u006f\\u006e\\u0074\\u0072\\u006f\\u006c\\u0020\\u004d\\u006f\\u0064\\u0065\",\"stereo\" : \"\\u0053\\u0074\\u0065\\u0072\\u0065\\u006f\\u0073\\u0063\\u006f\\u0070\\u0069\\u0063\\u0020\\u004d\\u006f\\u0064\\u0065\",\"other\" : \"\\u004f\\u0074\\u0068\\u0065\\u0072\\u0020\\u004f\\u0070\\u0074\\u0069\\u006f\\u006e\\u0073\",\"home\" : \"\\u0052\\u0065\\u0073\\u0065\\u0074\\u0020\\u004d\\u006f\\u0064\\u0065\",\"help\" : \"\\u0048\\u0065\\u006c\\u0070\\u0020\\u0066\\u006f\\u0072\\u0020\\u0043\\u006f\\u006e\\u0074\\u0072\\u006f\\u006c\\u006c\\u0065\\u0072\\u0020\\u004d\\u006f\\u0064\\u0065\"}, \"#360ErrorMessage\" : \"\\u0059\\u006f\\u0075\\u0020\\u0061\\u0072\\u0065\\u0020\\u0075\\u0073\\u0069\\u006e\\u0067\\u0020\\u0074\\u0068\\u0065\\u0020\\u0064\\u0065\\u0073\\u006b\\u0074\\u006f\\u0070\\u0020\\u0074\\u006f\\u0020\\u0061\\u0063\\u0063\\u0065\\u0073\\u0073\\u0020\\u0074\\u0068\\u0065\\u0020\\u0033\\u0036\\u0030\\u0020\\u006d\\u0065\\u006e\\u0075\\u002e\\u0020\\u0050\\u006c\\u0065\\u0061\\u0073\\u0065\\u0020\\u0075\\u0073\\u0065\\u0020\\u0061\\u0020\\u006d\\u006f\\u0062\\u0069\\u006c\\u0065\\u0020\\u0064\\u0065\\u0076\\u0069\\u0063\\u0065\\u0020\\u0074\\u006f\\u0020\\u0061\\u0063\\u0063\\u0065\\u0073\\u0073\\u0020\\u0074\\u0068\\u0069\\u0073\\u0020\\u0066\\u0065\\u0061\\u0074\\u0075\\u0072\\u0065\\u002e\",\"#previewErrorMessage\" : \"\\u0054\\u0068\\u0065\\u0020\\u0056\\u0065\\u0063\\u0074\\u006f\\u0072\\u0077\\u006f\\u0072\\u006b\\u