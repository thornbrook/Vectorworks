nnerHTML = resources[\"#helpStrings\"][\"helpViewDeskRot\"];\n        othTab = document.getElementById(\"orbitNavInfoTitleMid\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpViewZom\"];\n        othTab = document.getElementById(\"orbitNavInfoBodyMid\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpViewDeskZom\"];\n        othTab = document.getElementById(\"orbitNavInfoTitleRight\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpViewPan\"];\n        othTab = document.getElementById(\"orbitNavInfoBodyRight\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpViewDeskPan\"];\n        othTab = document.getElementById(\"firstTitle\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpFpTitle\"];\n        othTab = document.getElementById(\"rottitle\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpFpRot\"];\n        othTab = document.getElementById(\"rotex\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpFpDeskRotDisp\"];\n        othTab = document.getElementById(\"firstStep1Title\");\n        othTab.innerHTML = resources[\"#orbit_abt_fp\"];\n        othTab = document.getElementById(\"firstStep1Info\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpFpStep1Desk\"];\n\t\tothTab.innerHTML = replaceWithImgStr(othTab.innerHTML,'[eyeButton]', \"<img width='26' height='26' src='https://vgx.vectorworks.net/WebApp1.9.3/ControllerIcon.png'>\");\n        othTab = document.getElementById(\"orbitfpInfoInfo1\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpFpStep1Desk\"];\n        othTab.innerHTML = replaceWithImgStr(othTab.innerHTML,'[eyeButton]', \"<img width='26' height='26' src='https://vgx.vectorworks.net/WebApp1.9.3/ControllerIcon.png'>\");\n        othTab = document.getElementById(\"orbitfpInfoInfo2\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpFpStep2Desk\"];\n        othTab = document.getElementById(\"firstNavInfoTitle\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpFpNav\"];\n        othTab = document.getElementById(\"firstNavInfoInfo\");\n        othTab.innerHTML = resources[\"#helpStrings\"][\"helpFpNavDeskDisp\"];\n    }\n    othTab = document.getElementById(\"monoStereoTitle\");\n    othTab.innerHTML = resources[\"#helpStrings\"][\"helpSmTitle\"];\n    othTab = document.getElementById(\"walkText\");\n    othTab.innerHTML = resources[\"#helpStrings\"][\"helpSmWalk\"];\n    othTab = document.getElementById(\"fastText\");\n    othTab.innerHTML = resources[\"#helpStrings\"][\"helpSmFast\"];\n    othTab = document.getElementById(\"stopText\");\n    othTab.innerHTML = resources[\"#helpStrings\"][\"helpSmStop\"];\n    othTab = document.getElementById(\"slowText\");\n    othTab.innerHTML = resources[\"#helpStrings\"][\"helpSmSlow\"];\n    othTab = document.getElementById(\"monoStereoInfo\");\n    othTab.innerHTML = resources[\"#helpStrings\"][\"helpSmInfo1\"];\n    othTab = document.getElementById(\"stereoTitleHead\");\n    othTab.innerHTML = resources[\"#helpStrings\"][\"helpSmStereo\"];\n    othTab = document.getElementById(\"stereoInfo\");\n    othTab.innerHTML = resources[\"#helpStrings\"][\"helpSmInfo2\"];\n    othTab.innerHTML = replaceWithImgStr(othTab.innerHTML,'[cardboardButton]', \"<img width='26' height='26' src='https://vgx.vectorworks.net/WebApp1.9.3/cardboard.png'>\");\n    othTab = document.getElementById(\"fpsetting\");\n    othTab.innerHTML = resources[\"#Other Options App\"][\"FP Settings\"][\"def\"];\n    othTab = document.getElementById(\"collisionLabel\");\n    othTab.innerHTML = resources[\"#Other Options App\"][\"FP Settings\"][\"walkThru\"];\n    othTab = document.getElementById(\"walkLabel\");\n    othTab.innerHTML = resources[\"#Other Options App\"][\"FP Settings\"][\"walkSpeed\"];\n    othTab = document.getElementById(\"senseLabel\");\n    othTab.innerHTML = resources[\"#Other Options App\"][\"FP Settings\"][\"rotSense\"];\n    othTab = document.getElementById(\"startupTutorialPrmpt\");\n    othTab.innerHTML = resources[\"#tut_mes_1\"];\n}\n\n\tfunction ShowPopup(inText){\n\t\t$(\"#helpTxt\").css({ \"display\": \"block\" });\n        if (mobileAndTabletcheck())\n            $(\"#helpTxt\").css({ \"font-size\": \"100%\", \"color\" : \"black\" });\n\t\t$(\"#helpTxt\").text(inText);\n        $(\"#helpTxt\").css({\n            \"display\": \"inline\"\n        });\n        $(\"#myModal\").modal(\"toggle\");\n\t}\n\n    // Written by AGorbaty\n    function tswc() {\n        if (!(mobileAndTabletcheck()))\n        \tShowPopup(resources[\"#360ErrorMessage\"]);\n    }\n\n    function setAboutString(hours, minutes, seconds) {\n        $(\"#helpTxt\")[0].innerHTML = \"\";\n        if (window.location.href.indexOf(\"https://vgx.vectorworks.net\") > -1) {\n            $(\"#helpTxt\")[0].innerHTML += resources[\"#infoStrings\"][\"exTime\"];\n            $(\"#helpTxt\")[0].innerHTML += hours + resources[\"#infoStrings\"][\"hrs\"] + minutes + resources[\"#infoStrings\"][\"mins\"] + seconds + resources[\"#infoStrings\"][\"secs\"];\n            $(\"#helpTxt\")[0].innerHTML += \"<br/>\";\n        }\n        $(\"#helpTxt\")[0].innerHTML += resources[\"#infoStrings\"][\"faces\"];\n        $(\"#helpTxt\")[0].innerHTML += Math.floor(manager._modelInfo.numberOfTriangles);\n        $(\"#helpTxt\")[0].innerHTML += \"<br/>\";\n        $(\"#helpTxt\")[0].innerHTML += resources[\"#infoStrings\"][\"geoms\"];\n        $(\"#helpTxt\")[0].innerHTML += renderer.info.memory.geometries;\n        $(\"#helpTxt\")[0].innerHTML += \"<br/>\";\n        $(\"#helpTxt\")[0].innerHTML += resources[\"#infoStrings\"][\"texts\"];\n        $(\"#helpTxt\")[0].innerHTML += renderer.info.memory.textures;\n    }\n\n    function timeLeft() {\n        var element = document.querySelector('meta[property=\"uploadTime\"]');\n        if (element != null) {\n\t\t\tvar futureTime = new Date(element.getAttribute(\"data-uploadTime\"));\n\t        var currTime = new Date();\n\t        futureTime.setDate(futureTime.getDate() + 14);\n\t        var resultTime = futureTime - currTime;\n\t        var seconds = Math.floor(resultTime / 1000);\n\t        var minutes = Math.floor(seconds / 60);\n\t        var hours = Math.floor(minutes / 60);\n\t        var convMinutes = minutes % 60;\n\t        var convSeconds = seconds % 60;\n\t        setAboutString(hours, convMinutes, convSeconds);\n        }\n        else\n        \tsetAboutString(-1, -1, -1);\n    }\n\n    function displayAbout() {\n        $(\"#orbitNavHelp\").css({ \"display\": \"none\" });\n        $(\"#firstNavHelp\").css({ \"display\": \"none\" });\n        $(\"#monoStereoHelp\").css({ \"display\": \"none\" });\n        timeLeft();\n        $(\"#modalContext\").css({\n            background: \"transparent url('')\",\n            \"background-repeat\": \"no-repeat\",\n            \"background-size\": \"100% 100%\"\n        });\n        $(\"#helpTxt\").css({ \"display\": \"block\" });\n        fpcDis();\n        if (mobileAndTabletcheck())\n            $(\"#helpTxt\").css({ \"font-size\": \"100%\", \"color\" : \"black\" });\n        $(\"#myModal\").modal(\"toggle\");\n        lftTmr = setInterval(timeLeft, 1000);\n        $(\"#myModal\").on(\"hidden.bs.modal\", function () {\n            clearInterval(lftTmr);\n            fpcEn();\n        });\n    }\n\n    function forceUserIntoLandscape() {\n        var a = (window.orientation % 180 != 0);\n        if (!a) {\n\n            $('#octreeConfirmDivH').text(resources[\"#forceLandscape\"]);\n            $('#nobutton').hide();\n            $('#yesbutton').text(resources[\"#mes_ok\"]);\n            $('#msgModal').modal({ backdrop: 'static', keyboard: false }).on('click', '#yesbutton', function (e) { });\n        }\n    }\n\n    // Written by ProtoTech, categorized by AGorbaty\n    function progInit() {\n        var h = 50;\n        var e = renderer.domElement;\n        var f = h / (Math.tan(camera.fov / 2) * 350);\n        var j = f * (e.height / (2 * window.devicePixelRatio));\n        $(\"#svg #bar\").attr(\"r\", Math.abs(j));\n        $(\"#svg #barInner\").attr(\"r\", Math.abs(j));\n        $(\"#svg #bar\").attr(\"stroke-dasharray\", Math.abs(Math.PI * 2 * j));\n        $(\"#svg #barInner\").attr(\"stroke-dasharray\", Math.abs(Math.PI * 2 * j));\n        $(\"#svg #bar\").attr(\"stroke-dashoffset\", Math.abs(Math.PI * 2 * j));\n    }\n\n    /* Prototype method for now. Will be implemented later.\n    function activateMonoButtonFromTouch(event) {\n        var touchVector = new THREE.Vector3(0, 0, -1);\n        touchVector.applyQuaternion(gcm.quaternion);\n        touchVector.multiplyScalar(gcm.position);\n        touchVector.x = (event.clientX / window.innerWidth) * 2 - 1;\n        touchVector.y = -(event.clientY / window.innerHeight) * 2 + 1;\n        touchVector.normalize();\n        var touchRay = new THREE.Raycaster(gcm.position, touchVector, gcm.near, gcm.far);\n        touchRay.ray.origin.copy(gcm.position);\n        touchRay.ray.direction.copy(touchVector);\n        var intersection = b.intersectObjects(gmeme.children);\n        if (intersection) {\n            if (intersection.length > 0) {\n                if (gpid != intersection[0].object.id) {\n                    gpid = intersection[0].object.id;\n                    timeOutFunction();\n                }\n            }\n        }\n    }*/\n\n\n    // Written by AGorbaty\n    function skipProgressRender() {\n        var bCannotIncrementBar = (menuMesh.children[0].id == previousId && isSelected == 1) || (menuMesh.children[1].id == previousId && isSelected == 0);\n        if (bCannotIncrementBar) {\n            document.getElementById(\"bar\").removeEventListener(\"transitionend\", transEnd, false);\n            $(\"#svg #bar\").css({ visibility: \"hidden\" });\n            $(\"#svg #barInner\").css({ visibility: \"hidden\" });\n        }\n        else {\n            document.getElementById(\"bar\").addEventListener(\"transitionend\", transEnd, false);\n            $(\"#svg #bar\").css({ visibility: \"visible\" });\n            $(\"#svg #barInner\").css({ visibility: \"visible\" });\n        }\n        return bCannotIncrementBar;\n    }\n    function setNextToClosestObjectAsIntersection(){\n    \tif (gIntersections.length == 2)\n    \t\tgIntersections[0].object.visible = false;\n    \telse if (gIntersections.length > 2) {\n    \t\tgIntersections[0].object.visible = false;\n    \t\tgIntersections[1].object.visible = false;\n    \t}\n      renderer.animate(animate);\n      manager._renderAdaptor.render();\n\n    }\n\n    function resetGlobalIntersections(inRaycaster) {\n\t\tvar octreeObjects = [];\n        for(var tx = 0 ; tx < manager._octreeList.length; tx++ ){\n            var octObj = manager._octreeList[tx].search( inRaycaster.ray.origin, 40000000, true, inRaycaster.ray.direction );\n            for(var tx1 = 0 ; tx1 < octObj.length; tx1++ ){\n                octreeObjects.push(octObj[tx1]);\n            }\n        }\n        gIntersections = inRaycaster.intersectOctreeObjects(octreeObjects);\n        gIntersections.sort(function(a,b){return a.distance - b.distance});\n    }\n\n\n\n\n    // Written by ProtoTech, categorized by AGorbaty\n    function jumpToFirstPlaceOnGeometry(inStartPosition) {\n\t\trenderer.animate(animate);\n    \tvar modified = false;\n\t\tif(!manager._modelInfo.navigationMeshCreated){\n\t\t\tShowPopup(resources[\"#notdone\"]);\n\t\t\treturn modified;\n\t\t}\n        var camPos = new THREE.Vector3();\n        for (var tx1 = 0 ; tx1 < gIntersections.length; tx1++) {\n            if (gIntersections[tx1].object.material.opacity < 1 && tx1 != (gIntersections.length - 1))\n                continue;\n            else if (!gIntersections[tx1].object.visible)\n                continue;\n            else if (gIntersections[tx1].face.normal.z.toFixed(5) <= 0.00) {\n                modified = true;\n                var newRayPt = new THREE.Vector3();\n                newRayPt.copy(gIntersections[tx1].point);\n                var newRaYPtDir = new THREE.Vector3();\n                newRaYPtDir.copy(camera.getWorldDirection());\n                if (gIntersections[tx1].face.normal.z.toFixed(5) < 0.00)\n                    newRayPt.sub(newRaYPtDir.multiplyScalar(10));\n                else\n                    newRayPt.sub(newRaYPtDir.multiplyScalar(1500));\n\n                var flRayCast = new THREE.Raycaster(newRayPt, new THREE.Vector3(0, -1, 0), 0, 40000000);\n\n                var octreeObjects = [];\n                for (var tx = 0 ; tx < manager._octreeList.length; tx++) {\n                    var octObj = manager._octreeList[tx].search(flRayCast.ray.origin, 40000000, true, flRayCast.ray.direction);\n                    for (var tx1 = 0 ; tx1 < octObj.length; tx1++) {\n                        octreeObjects.push(octObj[tx1]);\n                    }\n                }\n                var hrIntersects = flRayCast.intersectOctreeObjects(octreeObjects);\n                if (hrIntersects.length > 0) {\n                    hrIntersects.sort(function (a, b) { return a.distance - b.distance });\n                    camPos.copy(hrIntersects[0].point);\n                }\n                else\n                    return;\n                break;\n            }\n            else {\n                modified = true;\n                camPos.copy(gIntersections[tx1].point);\n                break;\n            }\n        }\n        for (var i = 0 ; i < scene.children.length; i++) {\n            for (var j = 0 ; j < scene.children[i].children.length; j++) {\n                for (var k = 0 ; k < scene.children[i].children[j].children.length; k++) {\n                    scene.children[i].children[j].children[k].visible = true;\n                }\n            }\n        }\n        for (var j = 0; j < gIntersections.length; j++)\n        \tgIntersections[j].object.visible = true;\n        if (!modified)\n            return modified;\n        if (tweenTime >= 500) {\n        \tvar tweenAnim = new TWEEN.Tween( inStartPosition ).to( {x: camPos.x,y: camPos.y+controlsFRC.personHeight ,z: camPos.z}, tweenTime ).easing( TWEEN.Easing.Quadratic.In).start();\n      tweenQueue.push(tweenAnim);\n\t\t\tmanager._renderAdaptor.render = manager._renderAdaptor.setRender(manager._renderAdaptor._normalRenderer);\n\t\t\tmanager._renderAdaptor._cameraMoving = true;\n\t\t\ttweenAnim.onComplete(function(){\n\t\t\t\tmanager._renderAdaptor.render = manager._renderAdaptor.setRender(manager._renderAdaptor._composerRenderer);\n\t\t\t\tmanager._renderAdaptor._cameraMoving = false;\n\t\t\t\tmanager._renderAdaptor.render();\n        tweenQueue.pop();\n        if (tweenQueue.length == 0)\n          renderer.animate(null);\n\t\t\t});\n        \tif (tweenTime != 500)\n        \t\ttweenTime -= 500;\n        }\n        controlsFRC.object.position.copy(camPos);\n        controlsFRC.object.position.add(new THREE.Vector3(0, controlsFRC.personHeight, 0));\n        return modified;\n    }\n\n    // initiailization and animate\n\n    function update()\n    {\n        switch(controltype)\n        {\n            case 1: {\n                controlsORC.update();\n                camera.lookAt(controlsORC.target);\n\t\t\t\t\t\t\t\tbreak;\n            }\n            case 2: controlsFRC.update(); break;\n            case 3: {\n                        if (controlsDRC)\n                            controlsDRC.update();\n                        else\n                            controlsVR.update(stereoCamVector);\n                        break;\n            }\n            default: controlsORC.update(); break;\n        }\n\n        if (boxPos !== undefined) {\n\t        boxTarget.style.left = boxPos.x + 'px';\n\t\t\tboxTarget.style.top = boxPos.y + 'px';\n\t\t\tboxTarget.style.webkitTransform = 'rotate(' + Math.floor(boxPos.rotation) + 'deg)';\n\t\t\tboxTarget.style.MozTransform = 'rotate(' + Math.floor(boxPos.rotation) + 'deg)';\n\t\t\tif (updateCount <= 1800) {\n\t\t\t\tif (updateCount == 300) {\n\t\t\t\t\tTWEEN.remove(currTween);\n\t\t\t\t\tcurrTween = secondTween;\n\t\t\t\t\tif (mobileAndTabletcheck())\n\t\t\t\t\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_5\"];\n\t\t\t\t\telse\n\t\t\t\t\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_4\"];\n\t\t\t\t\tboxTargetTxt.innerHTML = replaceWithImgStr(boxTargetTxt.innerHTML,'[eyeButton]', \"<img width='26' height='26' src='https://vgx.vectorworks.net/WebApp1.9.3/ControllerIcon.png'>\");\n\t\t\t\t\tcurrTween.start();\n\t\t\t\t}\n\t\t\t\telse if (updateCount == 600 && mobileAndTabletcheck()){\n\t\t\t\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_6\"];\n\t\t\t\t\tboxTargetTxt.innerHTML = replaceWithImgStr(boxTargetTxt.innerHTML,'[360Button]', \"<img width='26' height='26' src='https://vgx.vectorworks.net/WebApp1.9.3/360.png'>\");\n\t\t\t\t}\n\t\t\t\telse if (updateCount == 900) {\n\t\t\t\t\tTWEEN.remove(currTween);\n\t\t\t\t\tcurrTween = thirdTween;\n\t\t\t\t\tif (mobileAndTabletcheck())\n\t\t\t\t\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_8\"];\n\t\t\t\t\telse\n\t\t\t\t\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_7\"];\n\t\t\t\t\tboxTargetTxt.innerHTML = replaceWithImgStr(boxTargetTxt.innerHTML,'[optButton]', \"<img width='26' height='26' src='https://vgx.vectorworks.net/WebApp1.9.3/settings.png'>\");\n\t\t\t\t\tcurrTween.start();\n\t\t\t\t}\n\t\t\t\telse if (updateCount == 1200) {\n\t\t\t\t\tif (mobileAndTabletcheck())\n\t\t\t\t\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_10\"];\n\t\t\t\t\telse\n\t\t\t\t\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_9\"];\n\t\t\t\t\tboxTargetTxt.innerHTML = replaceWithImgStr(boxTargetTxt.innerHTML,'[homeButton]', \"<img width='26' height='26' src='https://vgx.vectorworks.net/WebApp1.9.3/home.png'>\");\n\t\t\t\t}\n\t\t\t\telse if (updateCount == 1500) {\n\t\t\t\t\tTWEEN.remove(currTween);\n\t\t\t\t\tcurrTween = fourTween;\n\t\t\t\t\tif (mobileAndTabletcheck())\n\t\t\t\t\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_12\"];\n\t\t\t\t\telse\n\t\t\t\t\t\tboxTargetTxt.innerHTML = resources[\"#tut_mes_11\"];\n\t\t\t\t\tboxTargetTxt.innerHTML = replaceWithImgStr(boxTargetTxt.innerHTML,'[helpButton]', \"<img width='26' height='26' src='https://vgx.vectorworks.net/WebApp1.9.3/help.png'>\");\n\t\t\t\t\tcurrTween.start();\n\t\t\t\t}\n\t\t\t\telse if (updateCount == 1800) {\n\t\t\t\t\tTWEEN.remove(currTween);\n\t\t\t\t\tboxTarget.style.display = 'none';\n\t\t\t\t}\n\t\t\t\tupdateCount++\n\t\t\t}\n\t\t}\n    }\n\n\tfunction onDocumentFocus(){\n\t\tonWindowResize();\n\t\twindow.removeEventListener('focus', onDocumentFocus);\n    renderer.animate(animate);\n\t}\n\n\t/*window.onDocumentBlur = function() {\n\t\twindow.addEventListener('focus', onDocumentFocus);\n\t\trenderer.animate(null);\n\t}\n\n\twindow.addEventListener('blur', onDocumentBlur);*/\n\n\tfunction onWindowResize() {\n\t\trenderer.setSize(window.innerWidth - 1,window.innerHeight - 1);\n\t\tsetTimeout(function(){\n\t\t\t(manager._renderAdaptor._normalRenderer.windowResize())();\n\t\t\t(manager._renderAdaptor._composerRenderer.windowResize())();\n\n            if (stereoeffect !== undefined)\n                stereoeffect.setSize(window.innerWidth - 1,window.innerHeight - 1);\n\n\t\t\tvar canvas = renderer.domElement;\n\t\t\tvar wrad = 25;\n\n\t\t\tvar intradPix = wrad/(Math.tan(camera.fov/2) * 350)\n\t\t\tvar radPix = intradPix * (canvas.height / (2 * window.devicePixelRatio));\n\t\t\t$('#svg #bar').attr(\"r\",Math.abs(radPix));\n\t\t\t$('#svg #barInner').attr(\"r\",Math.abs(radPix));\n\t\t\t$('#svg #bar').attr(\"stroke-dasharray\",Math.abs(Math.PI*2*radPix));\n\t\t\t$('#svg #barInner').attr(\"stroke-dasharray\",Math.abs(Math.PI*2*radPix) );\n\t\t\t$('#svg #bar').attr(\"stroke-dashoffset\",Math.abs(Math.PI*2*radPix) );\n\t\t\trender();\n\t\t},500);\n    }\n\n\tfunction render() {\n\t\tbIsCollisionOn = $('#collisionbox').is(':checked');\n\t\tTWEEN.update();\n\t\tlight.position.copy(camera.position);\n\t\t// Following switch case is to be removed. The check in this render loop is not good.\n\t\t// We should create an interface and keep on switching the object it uses for rendering the scene.\n\t\tswitch (controltype){\n\t\t\tcase 3:{\n                    if (!bUsingPolyfill){\n                        stereoCamWrapper.position.copy(camera.position);\n                        if (HMDName.indexOf('OpenVR') != -1 || HMDName.indexOf('Oculus') != -1)\n                            stereoCamWrapper.position.multiplyScalar(1000);\n                        stereoCamWrapper.position.add(stereoCamVector);\n                    }\n                    else\n                        camera.position.copy(stereoCamVector);\n\n                    light.position.multiplyScalar(1000);\n                    light.position.add(stereoCamVector);\n\n                    if(bUsingPolyfill)\n                        stereoeffect.render(scene, camera);\n                    else\n                        renderer.render( scene, camera );\n\n                    if (HMDName.indexOf('OpenVR') == -1 && HMDName.indexOf('Oculus') == -1 && HMDName.indexOf('Daydream') == -1)\n                        menuRelatedSettings(bUsingPolyfill);\n\n                    switch(currentAction)\n                    {\n                        case 0:\n                            navigateCamera();\n                        break;\n                        case 1:  break;\n                        default: break;\n\n                    }\n                    break;\n            }\n\t\t\tcase 2:\n\t\t\tcase 1:\n\t\t\tdefault:\n\t\t\t\tmanager._renderAdaptor.render();\n\t\t\tbreak;\n\t\t}\n\t}\n\n\n    function animate() {\n\t    render();\n\t    update();\n\t};\n\n    function init() {\n        load2018Q1Elements();\n        if (mobileAndTabletcheck()) {\n            xRayMode = true;\n        }\n        if(window.innerWidth < 500 && window.innerHeight < 500){\n            //$(\"#FPCControllerDiv\").css({\"width\":\"135px\",\"height\":\"135px\" });\n\n            $(\"#leftW\").css({\"bottom\" : \"45px\",\"width\":\"45px\",\"height\":\"45px\" });\n            $(\"#rightW\").css({\"left\" : \"90px\",\"bottom\" : \"45px\",\"width\":\"45px\",\"height\":\"45px\"  });\n            $(\"#forwardW\").css({\"left\" : \"45px\",\"bottom\" : \"90px\",\"width\":\"45px\",\"height\":\"45px\"  });\n            $(\"#backwardW\").css({\"left\" : \"45px\",\"width\":\"45px\",\"height\":\"45px\"  });\n        }\n\n        $(\"#DefViewType\").on('click', function(event) {\n            event.preventDefault();\n            event.stopPropagation();\n            closeMenuItems();\n        });\n        $(document).on('click', function(e) {\n            if(fromFirstPerson && !mobileAndTabletcheck()){\n                fromFirstPerson = false;\n                return;\n            }\n            $(\"#view360menu\").css({\"display\":\"none\"});\n        });\n        $(document).keyup(function(event) {\n            if (event.keyCode == KEYCODE_ESC){\n                if(fpcPressed){\n                    document.removeEventListener(\"mouseup\", fpcMouseUp);\n                    document.removeEventListener(\"mousemove\", fpcMouseUp);\n                    document.removeEventListener(\"touchend\", fpcMouseUp);\n                    document.removeEventListener(\"touchmove\", fpcMouseUp);\n                    fpcPressed = false;\n                    if(flrTimer)\n                        clearTimeout(flrTimer);\n\n                    controlsFRC.enabled = true;\n\n                    if (mobileAndTabletcheck()) {\n                        $(\"#joystickButton\").css({display : \"inline\"});\n                    }\n                    for(var i = 0 ; i < scene.children.length;i++)\n                    {\n                        if(scene.children[i] instanceof THREE.Mesh == false)\n                            continue;\n                        for(var j = 0 ; j < scene.children[i].children.length;j++)\n                        {\n                            for(var k = 0 ; k < scene.children[i].children[j].children.length;k++) {\n                                scene.children[i].children[j].children[k].visible = true;\n                            }\n                        }\n                    }\n                    document.getElementById('mouseImg').style.display = 'none';\n                }\n            }\n            else if(event.keyCode == 66 || event.keyCode == 98){\n                xRayMode = !xRayMode;\n                if(flrTimer && !xRayMode)\n                    clearTimeout(flrTimer);\n                if(xRayMode && fpcPressed)\n                    flrTimer = setTimeout(flrtimeOutFunction, 2000);\n            }\n        });\n\n        renderer = new THREE.WebGLRenderer({ antialias : true });\n        renderer.setPixelRatio(window.devicePixelRatio);\n        renderer.setSize( window.innerWidth, window.innerHeight );\n        renderer.setClearColor( 0xf9f9f0);\n        renderer.shadowMap.enabled = true;\n        if(mobileAndTabletcheck())\n            renderer.shadowMap.type = THREE.BasicShadowMap; // allow for shadow calculations to be faster on mobile\n        else\n            renderer.shadowMap.type = THREE.PCFSoftShadowMap;\n        renderer.gammaInput = true;\n        renderer.gammaOutput = true;\n\n\t\trenderer.localClippingEnabled = true;\n\t\trenderer.clippingPlanes = [];\n\n        document.body.appendChild( renderer.domElement );\n\n        container = document.getElementById( 'container' );\n        container.appendChild(renderer.domElement );\n\n\t\tvar obtainVRDisp = function (){\n            WEBVR.getVRDisplay( function ( display ) {\n                if (display !== undefined){\n                    HMDName = display.displayName;\n                    if(!bUsingPolyfill)\n                        renderer.vr.setDevice( display );\n                    var vrButton = document.getElementById('vrbutton');\n                    WEBVR.setButton(vrButton, display, renderer.domElement, bUsingPolyfill );\n                }\n                else if (!isIOS13orAbove()) {\n                    $(\"#view360menubutton\").css({display: \"none\"});\n                    $(\"#camcontrol\").css({display: \"inline\", bottom:\"4px\", right:\"4px\"});\n                    $(\"#controlIndi\").css({display: \"inline\", bottom:\"4px\", right:\"45px\"})\n                }\n                if (display && !bUsingPolyfill){\n                  createVRControls(HMDName);\n                }\n                else if((display || isIOS13orAbove()) && bUsingPolyfill){\n                    controlsDRC = new THREE.DOC(camera);\n                    controlsDRC.enabled = false;\n                }\n            } );\n        };\n\n\n        bUsingPolyfill = !polyfill.hasNative;\n        obtainVRDisp();\n\n        scene = new THREE.Scene();\n        backgroundScene = new THREE.Scene();\n        scene.add( new THREE.AmbientLight(0x404040));\n\n        initCamera();\n\n\t\t\t\tstereoCamWrapper = new THREE.Object3D();\n\t\t\t\tscene.add(stereoCamWrapper);\n\t\t\t\tstereoCamWrapper.add(camera);\n\n        controlsORC = new THREE.OrbitControls(camera,renderer.domElement);\n        controlsFRC = new THREE.FirstPersonControls(camera, renderer.domElement);\n        controlsFRC.movementSpeed = 20;\n        controlsFRC.lookSpeed = 0.1;\n        controlsFRC.enabled = false;\n        controlsORC.enabled = true;\n\n        window.addEventListener( 'resize', onWindowResize, false );\n\n        camera.position.copy(rotateVectorForYUp(camera.position));\n\n        light.intensity  = 1.00000;\n        controlsORC.object.position.copy(camera.position);\n        controlsORC.position0.copy(camera.position);\n        controlsORC.target.copy(new THREE.Vector3(0,0,0));\n        controlsORC.target0.copy(new THREE.Vector3(0,0,0));\n\n        initializeMenu();\n        var cameraPos = new THREE.Vector3();\n        cameraPos.copy(camera.position);\n        previousCameraPos = camera.position.y;\n\n        var canvas = renderer.domElement;\n        var wrad = 25;\n        var intradPix = wrad/(Math.tan(80/2) * 350)\n        var radPix = intradPix * (canvas.height / (2 * window.devicePixelRatio));\n        $('#svg #bar').attr(\"r\",Math.abs(radPix));\n        $('#svg #barInner').attr(\"r\",Math.abs(radPix));\n        $('#svg #bar').attr(\"stroke-dasharray\",Math.abs(Math.PI*2*radPix));\n        $('#svg #barInner').attr(\"stroke-dasharray\",Math.abs(Math.PI*2*radPix) );\n        $('#svg #bar').attr(\"stroke-dashoffset\",Math.abs(Math.PI*2*radPix) );\n\n        document.getElementById(\"bar\").addEventListener('transitionend', transEnd, false);\n        controlsFRC.personHeight = 1524; // 5 ft (AKA 1.524 meters)\n\n\t\trenderer.animate(animate);\n\n\t\tmanager = new VWManager(scene,backgroundScene,camera);\n\t\tmanager.loadModel();\n        manager._defaultLight = light;\n\n\n        controlsLOC = new LightOrientationControls(manager);\n        controlsLOC.init(50,50);\n\n\n\n\t\tif (mobileAndTabletcheck())\n\t\t\tcreateJoystick();\n\n        // start of private methods within init function\n\n        // load web view features released in February/March 2018\n        function load2018Q1Elements(){\n          var optionsMenu = document.getElementById('flyMenu');\n          var separator = optionsMenu.innerHTML.lastIndexOf('<div class=\\\"panel panel-default\\\"');\n          var firstPart = optionsMenu.innerHTML.slice(0, separator);\n          var secondPart = optionsMenu.innerHTML.slice(separator, optionsMenu.length);\n\n          var shadowOptionsStr = \"Shadow Options\";\n          var displayShadowsStr = \"Display Shadows\";\n          var lightDirStr = \"Light Direction\";\n          if (resources[\"#Other Options App\"][\"Shadow Settings\"] !== undefined){\n            shadowOptionsStr = resources[\"#Other Options App\"][\"Shadow Settings\"][\"shadowOptionsStr\"];\n            displayShadowsStr = resources[\"#Other Options App\"][\"Shadow Settings\"][\"displayShadowsStr\"];\n            lightDirStr = resources[\"#Other Options App\"][\"Shadow Settings\"][\"lightDirStr\"];\n          }\n\n          var shadowOptions = \"<div class=\\\"panel panel-default\\\" style=\\\"background-size: 100%;background-color:rgba(145,145,145,0.9);border-radius:10px; border:none;border-bottom-style: solid;font-family:DINCondensed-Bold, Arial;\\\">\\n<div class=\\\"panel-heading\\\" style=\\\"background-size: 100%;background-color:rgba(145,145,145,0.9);border-radius:10px;\\\">\\n<h4 class=\\\"panel-title\\\"><a id=\\\"biasSetting\\\" data-toggle=\\\"collapse\\\" data-parent=\\\"#accordion\\\" href=\\\"#collapse3\\\" style=\\\"font-family:DINCondensed-Bold, Arial\\\">\" + shadowOptionsStr + \" </a></h4>\\n</div>\\n<div id=\\\"collapse3\\\" class=\\\"panel-collapse collapse in\\\">\\n<div class=\\\"panel-body\\\">\\n<label id=\\\"shadowLabel\\\">\"+ displayShadowsStr + \" </label><input type=\\\"checkbox\\\" id=\\\"shadowBoxId\\\" name=\\\"shadowBox\\\"><br><br>\\n <label id=\\\"shadowLabel\\\">\" + lightDirStr + \" </label><br>\\n<canvas id=\\\"shadowDirControl\\\" height=\\\"100\\\" width=\\\"100\\\"></canvas>\\n</div>\\n</div>\\n</div>\"\n          optionsMenu.innerHTML = firstPart + shadowOptions + secondPart;\n\n          $('input[name=shadowBox]').change(function(){\n              if (this.checked)\n                  manager.SwitchDefaultLight(true);\n              else\n                  manager.SwitchDefaultLight(false);\n\t\t\tmanager._renderAdaptor.render();\n          });\n\n          var appButtons = document.getElementById('DefViewType').parentElement;\n          var clipCubeBtn = document.createElement('button');\n          var cubeOffImgUrl = window.Configuration.withStaticPrefix('cubeOff.png');\n          clipCubeBtn.id = \"clipCubeBtn\";\n          clipCubeBtn.className = \"dvviews\";\n          clipCubeBtn.title = (resources['#clip_cube'] !== undefined) ? resources['#clip_cube'] : \"Clip Cube\";\n          clipCubeBtn.style = \"border-style:none;background:transparent url('\" + cubeOffImgUrl + \"');width: 56px;height: 56px;top:112px;right:0px;background-size: 100%;z-index: 2;\"\n          clipCubeBtn.onmousedown = function(event){event.preventDefault();event.stopPropagation();switchInteractiveClipCube()};\n          clipCubeBtn.ontouchstart = function(event){event.preventDefault();event.stopPropagation();switchInteractiveClipCube()};\n          appButtons.appendChild(clipCubeBtn);\n        }\n\n\t\tfunction createVRControls(inHMDName){\n\t\t\tvar device = inHMDName.indexOf('OpenVR') != -1 || inHMDName.indexOf('Oculus VR HMD') != -1 ? VRDeviceSelect.Vive : inHMDName.indexOf('Daydream') != -1 || inHMDName.indexOf('Oculus Go') != -1 ? VRDeviceSelect.Daydream : VRDeviceSelect.Cardboard;\n\t        controlsVR = new VRControllerAdaptor(scene, camera, {SelectedDevice:device, PersonHeight:controlsFRC.personHeight});\n\t        controlsVR.setControllerVisibility(false);\n\t\t};\n\n\t\tfunction bindJoystick () {\n\t        joystick.on('end', function (evt, data) {\n\t           joystickDir = null;\n\t        }).on('move', function (evt, data) {\n\t        \tjoystickDir =  data['angle'];\n\t        \tjoystickDir['degree'] = joystickDir['degree'].toFixed(2);\n\t        });\n\t    };\n\n\t    function createJoystick () {\n\t        var staticJoy = {\n\t            zone: document.querySelector('.button_static'),\n\t            mode: 'static',\n\t            position: {left: '150px', bottom: '100px'},\n\t            color: 'black'\n\t        };\n\t        joystick = nipplejs.create(staticJoy);\n\t        bindJoystick();\n\t    };\n\n      // need to put this here to allow sliders to work\n      $('input[type=\"range\"]').rangeslider({\n          polyfill: true\n        }).on('input', function() {\n          if (this.id == 'walkSlide')\n              walkingspeed = this.value;\n          else if (this.id == \"senseSlide\")\n            sensitivity = 0.002 * (this.value/ (this.max/2));\n      });\n    }\n\n    $(\"#startupTutorial\").css({display:'block'});\n\n    function initCamera(){\n        //if(c.cType.localeCompare(\"P\") == 0){\n            camera = new THREE.PerspectiveCamera( 60, window.innerWidth / window.innerHeight,300, 2000000 );\n        /*}\n        else{\n            camera = new THREE.OrthographicCamera(1500,1500,1500,1500,300,2000000);\n        }*/\n        camera.position.x = 1000.0;\n        camera.position.y = 1000.0;\n        camera.position.z = 1000.0;\n        camera.up.x = 0.0;\n        camera.up.y = 1.0;\n        camera.up.z = 0.0;\n\n\n        light = new THREE.PointLight(0xffffff);\n        light.position.x = 1000.0;\n        light.position.y = 1000.0;\n        light.position.z = 1000.0;\n        light.intensity  = 0.6;\n\t\tlight.decay  = 2.0;\n\t\tlight.castShadow = false;\n        light.visible = false;\n        scene.add(light);\n    }\n\n\n\n    function createSkyboxMesh(skyBoxMaterial){\n        var defaultSize = 1000000;\n        skyBox = new THREE.Mesh(\n            new THREE.BoxGeometry( defaultSize, defaultSize, defaultSize ),\n            skyBoxMaterial\n        );\n\t\tskyBox.geometry.computeVertexNormals();\n    }\n\n    function createStaticBackground(skyBoxMaterial){\n        skyBox = new THREE.Mesh(\n            new THREE.PlaneGeometry( 2, 2),\n             skyBoxMaterial\n        );\n        //skyBox.rotation.z = Math.PI;\n        skyBoxMaterial.depthTest = false;\n        skyBoxMaterial.depthWrite = false;\n        manager._backGroundCamera = new THREE.Camera();\n        manager._renderAdaptor._normalRenderer._backgroundRenderPass.camera = new THREE.Camera();\n        manager._renderAdaptor._composerRenderer._backgroundRenderPass.camera = new THREE.Camera();\n        manager._backgroundScene.add( skyBox );\n        manager._backgroundScene.staticBackground = true;\n    }\n\n\tfunction initCubeMapTexture(inTexData, max, min) {\n        var texture_placeholder = document.createElement( 'canvas' );\n        var bgImages = Configuration.backgroundImages || {};\n        texture_placeholder.width = 128;\n        texture_placeholder.height = 128;\n        var materials;\n        // these statements were added for loading the background (AGorbaty)\n\n        var defaultSize = 1000000;\n        var maxSize =  -1;\n        if (max !== undefined && min != undefined)\n            maxSize = Math.max(Math.max(max.x - min.x,max.y - min.y), max.z - min.z );\n\n        if (inTexData !== undefined && inTexData['bkrndImg.png'] !== undefined) {\n            // TO DO : Complete the static background rendering.\n            var skyBoxMaterial = loadTexture( inTexData['bkrndImg.png'], texture_placeholder)\n            //var skyBoxMaterial = loadTexture( 'bkrndImg.png', texture_placeholder)\n            createStaticBackground(skyBoxMaterial);\n        }\n        else if (maxSize > defaultSize) {\n            var skyBoxMaterial = null;\n            if (inTexData !== undefined && inTexData['ny.png'] !== undefined)\n                skyBoxMaterial = loadTexture( inTexData['ny.png'], texture_placeholder)\n            else\n                skyBoxMaterial = loadTexture( bgImages['ny.png'] || 'ny.png', texture_placeholder)\n            createStaticBackground(skyBoxMaterial);\n        }\n        else if (inTexData !== undefined && inTexData['px.png'] !== undefined){\n            materials = [\n                loadTexture( inTexData['px.png'], texture_placeholder), // right\n                loadTexture( inTexData['nx.png'], texture_placeholder), // left\n                loadTexture( inTexData['ny.png'], texture_placeholder), // top\n                loadTexture( inTexData['py.png'], texture_placeholder), // bottom\n                loadTexture( inTexData['pz.png'], texture_placeholder), // back\n                loadTexture( inTexData['nz.png'], texture_placeholder) // front\n            ];\n\n            var skyBoxMaterial = new THREE.MeshFaceMaterial( materials )\n            createSkyboxMesh(skyBoxMaterial);\n            skyBox.rotation.z = Math.PI;\n            backgroundScene.add( skyBox );\n        }\n        else {\n            materials = [\n                loadTexture( bgImages['px.png'] || 'px.png', texture_placeholder), // right\n                loadTexture( bgImages['nx.png'] || 'nx.png', texture_placeholder), // left\n                loadTexture( bgImages['ny.png'] || 'ny.png', texture_placeholder), // top\n                loadTexture( bgImages['py.png'] || 'py.png', texture_placeholder), // bottom\n                loadTexture( bgImages['pz.png'] || 'pz.png', texture_placeholder), // back\n                loadTexture( bgImages['nz.png'] || 'nz.png', texture_placeholder) // front\n            ];\n\n            var skyBoxMaterial = new THREE.MeshFaceMaterial( materials )\n            createSkyboxMesh(skyBoxMaterial);\n            skyBox.rotation.z = Math.PI;\n            backgroundScene.add( skyBox );\n        }\n    }\n\n    function loadTexture( path , texture_placeholder) {\n        var texture = new THREE.Texture( texture_placeholder );\n        var material = new THREE.MeshBasicMaterial( { map: texture, overdraw: 0.5, side : THREE.DoubleSide  } );\n\n        var image = new Image();\n        image.crossOrigin = 'anonymous';\n        image.onload = function () {\n\n            texture.image = this;\n            texture.needsUpdate = true;\n\n        };\n        image.src = path;\n\n        return material;\n\n    }\n\n\n    function fpcMouseDown(event){\n        if(!fpcPressed){\n            if((!octCanBeBuild) && (!toBuildOrNot)){\n                ShowPopup(resources[\"#notdone\"]);\n                return;\n            }\n            mouseHasMoved = false;\n            if (mobileAndTabletcheck()) {\n                $(\"#joystickButton\").css({display : \"none\"});\n            }\n            controlsORC.enabled = false;controlsFRC.enabled = false;\n            $(document).trigger('mousedown');\n            document.addEventListener(\"mouseup\", fpcMouseUp);\n            document.addEventListener(\"mousemove\", fpcMouseMove);\n            document.addEventListener(\"touchend\", fpcMouseUp);\n            document.addEventListener(\"touchmove\", fpcMouseMove);\n            document.getElementById(\"camcontrol\").addEventListener(\"mousemove\", fpcMouseMoveBut, false);\n            document.getElementById(\"controlIndi\").addEventListener(\"mousemove\", fpcMouseMoveBut, false);\n            fpcPressed = true;\n        }\n    }\n\n    function fpcMouseMoveBut(event){\n        event.preventDefault();\n        event.stopPropagation();\n    }\n\n    function fpcMouseMove(event){\n        mouseHasMoved = true;\n        if(controltype == 3)\n            return;\n        if(fpcPressed){\n            if((!octCanBeBuild)){\n                return;\n            }\n\n            event.preventDefault();\n            event.stopPropagation();\n            document.getElementById('mouseImg').style.display = 'inline';\n            if (mobileAndTabletcheck())\n                $(\"#mouseImg\").css({left:event.touches[0].pageX - 28, top:event.touches[0].pageY - 38});\n            else\n                $(\"#mouseImg\").css({left:event.pageX, top:event.pageY});\n            if(flrTimer)\n                clearTimeout(flrTimer);\n            var flRayCast = new THREE.Raycaster( camera.position, camera.getWorldDirection() , 0, 40000000);\n            var mouse = new THREE.Vector2();\n            if (mobileAndTabletcheck()){\n                mouse.x = ( event.touches[0].clientX / window.innerWidth ) * 2 - 1;\n                mouse.y = - ( event.touches[0].clientY / window.innerHeight ) * 2 + 1;\n            }\n            else{\n                mouse.x = ( event.clientX / window.innerWidth ) * 2 - 1;\n                mouse.y = - ( event.clientY / window.innerHeight ) * 2 + 1;\n            }\n            flRayCast.setFromCamera( mouse, camera );\n\n            resetGlobalIntersections(flRayCast);\n            if(xRayMode)\n                flrTimer = setTimeout(flrtimeOutFunction, 1500);\n        }\n    }\n\n    function flrtimeOutFunction(){\n        if(fpcPressed){\n            if(flrTimer)\n                clearTimeout(flrTimer);\n            var cp = new THREE.Vector3();\n\t\t\tif(!manager._modelInfo.navigationMeshCreated){\n\t\t\t\tShowPopup(resources[\"#notdone\"]);\n\t\t\t\treturn;\n\t\t\t}\n            gIntersections.sort(function(a,b){return a.distance - b.distance});\n\n            for(var tx1 = 0 ; tx1 < gIntersections.length; tx1++ ){\n                if(!gIntersections[tx1].object.visible){\n                    continue;\n                }\n                else{\n                    var bbMesh = true;\n                    if(gIntersections[tx1].object.itsChildArray){\n                        for(var i = 0 ; i < gIntersections[tx1].object.itsChildArray.length; i++){\n                            if(scene.getObjectById(gIntersections[tx1].object.itsChildArray[i]).visible){\n                                bbMesh = false;\n                                gIntersections[tx1].object.visible = false;\n                                scene.getObjectById(gIntersections[tx1].object.itsChildArray[i]).visible = false;\n                            }\n                        }\n                    }\n                    if(xRayMode)\n                        flrTimer = setTimeout(flrtimeOutFunction, 1500);\n                    if(bbMesh){\n                        gIntersections[tx1].object.visible = false;\n                        for(var tx = tx1; tx < gIntersections.length; tx++){\n                            if((gIntersections[tx1].point.distanceTo(gIntersections[tx].point)) < 1700){\n                                gIntersections[tx].object.visible = false;\n                            }\n                            else\n                                break;\n                        }\n                    }\n                    break;\n                }\n            }\n        }\n    }\n\n    function SetRaycasterBasedOnMouse(event) {\n    \tvar mouse = new THREE.Vector2();\n    \tif (mobileAndTabletcheck()) {\n    \t\tif (event.changedTouches !== undefined) {\n    \t\t\tmouse.x = ( event.changedTouches[0].clientX / window.innerWidth ) * 2 - 1;\n    \t\t\tmouse.y = -( event.changedTouches[0].clientY / window.innerHeight ) * 2 + 1;\n    \t\t}\n    \t\telse {\n    \t\t\tmouse.x = ( event.clientX / window.innerWidth ) * 2 - 1;\n\t    \t\tmouse.y = -( event.clientY / window.innerHeight ) * 2 + 1;\n    \t\t}\n        }\n        else {\n    \t\tmouse.x = ( event.clientX / window.innerWidth ) * 2 - 1;\n    \t\tmouse.y = -( event.clientY / window.innerHeight ) * 2 + 1;\n        }\n\t\tvar raycaster = new THREE.Raycaster(camera.position, THREE.Vector3() , 0, 40000000);\n\t\traycaster.setFromCamera(mouse, camera);\n\t\tresetGlobalIntersections(raycaster);\n    }\n\n    function DoSwitchToFPorOrbit() {\n        if(controltype == 2){\n            controlsFRC.enabled = true;\n            if (mobileAndTabletcheck() && octCanBeBuild) {\n                $(\"#joystickButton\").css({display : \"inline\"});\n            }\n        }\n\t\t\t\telse\n            controlsORC.enabled = true\n\n        if(controltype == 3)\n            return;\n\n        if(flrTimer)\n            clearTimeout(flrTimer);\n        var modified = false;\n\n        if (((controltype == 1 || (controltype == 2 && mouseHasMoved)) && fpcPressed) || (!fpcPressed && !mouseHasMoved)) { // orbit-->FP when pressing button/drag and drop/single click without moving mouse or finger\n        \tvar startPos = controlsFRC.object.position;\n        \tif (!mouseHasMoved && fpcPressed) {\n        \t\tvar flRayCast =  null;\n        \t\tflRayCast = new THREE.Raycaster( camera.position, new THREE.Vector3( 0, -1, 0 ) , 0, 40000000);\n\t            resetGlobalIntersections(flRayCast);\n\t            startPos = controlsORC.object.position;\n        \t}\n        \tif (gIntersections.length || fpcPressed) {\n\t        \tmodifyController(2);\n\t        \tvar bDidMove = jumpToFirstPlaceOnGeometry(startPos);\n\t        \tif (bDidMove){\n                  switchInteractiveClipCube({isCCOn: false, isBtnVis : false, doReset : false });\n\t        \t\tif (mobileAndTabletcheck())\n\t        \t\t\t$(\"#joystickButton\").css({display : \"inline\"});\n\t        \tif (bFirstTimeVisitingFP){\n\t\t\t        \tif(mobileAndTabletcheck())\n\t\t\t\t\t\tboxTarget2Txt.innerHTML = resources[\"#tut_mes_14\"];\n\t\t\t\t\telse\n\t\t\t\t\t\tboxTarget2Txt.innerHTML = resources[\"#tut_mes_13\"];\n\t\t\t        boxTarget2.style.display = 'block';\n\t        \t}\n\t        }\n\t        \telse {\n\t        \t\tif (mobileAndTabletcheck())\n\t        \t\t\t$(\"#joystickButton\").css({display : \"none\"});\n\t        \t}\n\n\t        }\n        }\n        else if (controltype == 2 && !mouseHasMoved && fpcPressed){ // FP-->orbit when pressing button\n        \tmodifyController(1);\n            switchInteractiveClipCube({isCCOn: false, isBtnVis : true, doReset : false });\n        \tboxTarget2.style.display = 'none';\n        }\n\n        mouseHasMoved = false;\n        fpcPressed = false;\n    }\n\n\n    function fpcMouseUp(event){\n        if(fpcPressed){\n            $(\"#view360menu\").css({\"display\":\"none\"});\n            $(\"#flyMenu\").css({\"display\":\"none\"});\n            event.preventDefault();\n            event.stopPropagation();\n            document.removeEventListener(\"mouseup\", fpcMouseUp);\n            document.removeEventListener(\"mousemove\", fpcMouseUp);\n            document.removeEventListener(\"touchend\", fpcMouseUp);\n            document.removeEventListener(\"touchmove\", fpcMouseUp);\n            document.getElementById(\"camcontrol\").removeEventListener(\"mousemove\", fpcMouseMoveBut, false);\n            document.getElementById(\"controlIndi\").removeEventListener(\"mousemove\", fpcMouseMoveBut, false);\n            document.getElementById('mouseImg').style.display = 'none';\n            DoSwitchToFPorOrbit();\n        }\n    }\n\n    function modifyController(type){\n\n        $('#svg').css({ \"display\":\"none\"});\n        if (mobileAndTabletcheck()) {\n            $(\"#joystickButton\").css({display : \"none\"});\n        }\n        $(\"#flyMenu\").css({\"display\":\"none\"});\n        if(type != 3 && controltype == 3){\n            changeGeometry(false);\n        }\n        switch(type){\n            case 1: {controltype = 1;setResetStereo(false);controlsORC.enabled = true;controlsFRC.enabled = false;camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0; $(\"#controlIndi\").attr('src', \"https://vgx.vectorworks.net/WebApp1.9.3/OrbitController.png\").load(); $(\"#joystickButton\").css({display : \"none\"});\n\t\t\tbackgroundScene.add(skyBox);\n\t\t\tscene.remove(skyBox);\n\t\t\trenderer.autoClear = false;\n\t\t\tbreak;}\n            case 2: {controltype = 2;setResetStereo(false);controlsFRC.setHeightFirstTime = true;controlsFRC.enabled = true;controlsORC.enabled = false;camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0; $(\"#controlIndi\").attr('src', \"https://vgx.vectorworks.net/WebApp1.9.3/FirstController.png\").load();\n                if (mobileAndTabletcheck() && octCanBeBuild) {\n                    $(\"#joystickButton\").css({display : \"inline\"});\n                }\n\t\t\tbackgroundScene.add(skyBox);\n\t\t\tscene.remove(skyBox);\n\t\t\trenderer.autoClear = false;\n\t\t\tbreak;}\n            case 3: {controltype = 3;controlsFRC.enabled = false;controlsORC.enabled = false;camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0;$(\"#joystickButton\").css({display : \"none\"});\n            if (controlsDRC && bUsingPolyfill)\n                controlsDRC.enabled = true;\n            scene.add(skyBox);\n\t\t\tbackgroundScene.remove(skyBox);\n\t\t\tcamera.updateProjectionMatrix();\n\t\t\trenderer.autoClear = true;\n\t\t\trenderer.animate(animate);\n\t\t\tbreak;}\n            default: {controltype = 1;setResetStereo(false);controlsORC.enabled = true;controlsFRC.enabled = false;break;}\n        }\n\n        if(type != 3){\n\n            renderer.setViewport( 0, 0, window.innerWidth,  window.innerHeight  );\n        }\n        if((type == 2 || type == 3) && (!octCanBeBuild) && (!toBuildOrNot)){\n            ShowPopup(resources[\"#notdone\"]);\n        }\n\n    }\n\n    function requestPermissionForOrientation(){\n      if (isIOS13orAbove()){\n        window.DeviceOrientationEvent.requestPermission()\n        .then(response => {\n          if (response == 'granted') {\n            window.addEventListener('deviceorientation', () => {});\n          }\n        })\n        .catch(console.error);\n      }\n    }\n\n    function displayStereoScopic() {\n\t\t// cannot continue if the VRControls have not been initalized.\n\t\tif (!bUsingPolyfill && controlsVR === undefined){\n\t\t\tShowPopup(resources[\"#notdone\"]);\n\t\t\treturn;\n\t\t}\n\n    requestPermissionForOrientation();\n\n\t\t$(\"#orbitControl\").css({\"background-color\":\"rgba(145,145,145,0.501)\"});\n        $(\"#firstperson\").css({\"background-color\":\"rgba(145,145,145,0.501)\"});\n        $(\"#flyMenu\").css({\"display\":\"none\"});\n\n        renderer.clippingPlanes = [];\n        if(!bUsingPolyfill){\n            renderer.setSize( window.innerWidth, window.innerHeight );\n            renderer.vr.enabled = true;\n            controlsVR.setControllerVisibility(true);\n            stereoCamWrapper.position.copy(camera.position);\n        }\n        else{\n            if (stereoeffect === undefined) {\n                stereoeffect = new THREE.VREffect(renderer);\n            }\n            stereoeffect.setSize(window.innerWidth, window.innerHeight);\n        }\n\t\tstereoCamVector.copy(camera.position);\n\n\t\tswitchInteractiveClipCube({isCCOn: false, isBtnVis : false, doReset : true });\n\n        if(controltype != 3){\n        \tsetResetStereo(true);\n            changeGeometry(true);\n        }\n        modifyController(3);\n        isSelected = 0;\n        camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0;\n        renderer.setViewport( 0, 0, window.innerWidth,  window.innerHeight  );\n        if(camera.fov){\n            camera.fov = 80;\n            camera.near = 300;\n            camera.far = 2000000;\n            camera.updateProjectionMatrix();\n        }\n        $(\"#walkSpeed\").css({\"width\":\"100%\"});\n        //////////////////////////\n\t\tif (HMDName.indexOf('OpenVR') != -1 || HMDName.indexOf('Oculus') != -1 || HMDName.indexOf('Daydream') != -1){\n\t\t    for (var d = 0; d < menuMesh.children.length; d++)\n\t\t       menuMesh.children[d].visible = false;\n\t\t      circleIndi.visible = false;\n\t\t      circle3.visible = false;\n\t\t      isSelected = -1;\n\t    }\n\t    else{\n\t\t    for (var g = 0; g < menuMesh.children.length; g++)\n\t\t\t{\n\t\t        menuMesh.children[g].scale.set(1, 1, 1);\n\t\t\t\tmenuMesh.children[g].visible = true;\n\t\t\t}\n\t\t\tcircleIndi.visible = true;\n\t\t     circle3.visible = true;\n\t        circle3.scale.set(1, 1, 1);\n\t    }\n        $(\"#controlIndi\").css({\n            display: \"none\"\n        });\n        $(\"#camcontrol\").css({\n            display: \"none\"\n        });\n        $(\"#flyMenu\").css({\n            display: \"none\"\n        });\n        $(\"#DefViewType\").css({\n            display: \"none\"\n        });\n        $('#vrbutton').css({ display: \"inline\" });\n        $(\"#view360menubutton\").css({display: \"none\"});\n        if (bFirstTimeVisitingStereo) {\n\t\t\tboxTarget2.style.display = 'block';\n\t\t\tboxTarget2Txt.innerHTML = resources[\"#tut_mes_15\"];\n\t\t\tbFirstTimeVisitingStereo = false;\n        }\n\n        progInit();\n\n    }\n\n\n    function changeGeometry(isStereo){\n\n        if(!isStereo){\n            if(camera.fov){\n                camera.fov = manager._originalCamFOV;\n                camera.far = manager._originalCamFar;\n                camera.near = manager._originalCamNear;\n                camera.updateProjectionMatrix();\n\n            }\n        }\n    }\n\n    function resetView() {\n        if(!bUsingPolyfill)\n            renderer.vr.enabled = false;\n\n\t\trenderer.clippingPlanes = manager._ccPlanes;\n\t\tif (controlsVR !== undefined)\n            controlsVR.setControllerVisibility(false);\n        if (controlsDRC)\n            controlsDRC.enabled = false;\n        $(\"#controlIndi\").attr('src', \"https://vgx.vectorworks.net/WebApp1.9.3/OrbitController.png\").load();\n        $(\"#firstperson\").css({\"background-color\":\"rgba(145,145,145,0.501)\"});$(\"#orbitControl\").css({\"background-color\":\"rgba(102,255,255,0.501)\"});\n        $(\"#flyMenu\").css({\"display\":\"none\"});\n        $('#svg').css({ \"display\":\"none\"});\n        if(controltype == 3){\n\t\t\tstereoCamWrapper.position.copy(new THREE.Vector3(0,0,0));\n            stereoCamVector.copy(new THREE.Vector3(0,0,0));\n            changeGeometry(false);\n            for (var d = 0; d < menuMesh.children.length; d++) {\n                menuMesh.children[d].visible = false;\n            }\n            circleIndi.visible = false;\n            circle3.visible = false;\n            isSelected = -1;\n        }\n        modifyController(1);\n        camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0;\n        controlsORC.enabled = true;controlsFRC.enabled = false;\n        controlsORC.reset();\n        if (manager._clipSimulation !== undefined)\n\t\t\tmanager._clipSimulation.camera.copy(camera);\n        switchInteractiveClipCube({isCCOn: false, isBtnVis : true, doReset : true });\n        if (mobileAndTabletcheck())\n            $(\"#joystickButton\").css({display : \"none\"});\n\n\t\tif (HMDName.length != 0 || isIOS13orAbove()){\n            $('#vrbutton').css({ display: \"none\" });\n            $(\"#view360menubutton\").css({display: \"inline\"});\n        }\n        $(\"#controlIndi\").css({display: \"inline\"});\n        $(\"#camcontrol\").css({display: \"inline\"});\n        $(\"#flyMenu\").css({display: \"none\"});\n        $(\"#DefViewType\").css({display: \"inline\"});\n        $(\"#walkSpeed\").css({display: \"none\"});\n        $(\"#walkSpeed1\").css({ display: \"none\" });\n        mouseHasMoved = false;\n        enteredStereo = false;\n        if (boxTarget2 !== undefined)\n        \tboxTarget2.style.display = 'none';\n    light.position.copy(camera.position);\n\t\tmanager._renderAdaptor.render();\n    }\n\n    function changeView(ip) {\n        $(\"#controlIndi\").attr('src', \"https://vgx.vectorworks.net/WebApp1.9.3/OrbitController.png\").load();\n        $(\"#firstperson\").css({\"background-color\":\"rgba(145,145,145,0.501)\"});$(\"#orbitControl\").css({\"background-color\":\"rgba(102,255,255,0.501)\"});\n        if(controltype == 3){\n            changeGeometry(false);\n        }\n        switch(ip)\n        {\n            case 'Left': controlsORC.object.position.copy(new THREE.Vector3(0.0,0.0,-44003.546577));controlsORC.target.copy(new THREE.Vector3( 0, 0, 1 ));controlsORC.object.rotation.x = 0.0;controlsORC.object.rotation.y = 0.0;controlsORC.object.rotation.z = 0.0; camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0;break;\n            case 'Right': controlsORC.object.position.copy(new THREE.Vector3(0.0,0.0,44003.546577));controlsORC.target.copy(new THREE.Vector3( 0, 0, -1 ));controlsORC.object.rotation.x = 0.0;controlsORC.object.rotation.y = 0.0;controlsORC.object.rotation.z = 0.0; break;\n            case 'Top': controlsORC.object.position.copy(new THREE.Vector3(0.0,44003.546577,0.0));controlsORC.target.copy(new THREE.Vector3( 0, -1, 0 ));controlsORC.object.rotation.x = 0.0;controlsORC.object.rotation.y = 0.0;controlsORC.object.rotation.z = 0.0;if(controltype != 1 && controltype != 2){camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0;} break;\n            case 'Bottom': controlsORC.object.position.copy(new THREE.Vector3(0.0,-44003.546577,0.0));controlsORC.target.copy(new THREE.Vector3( 0, 1, 0 ));controlsORC.object.rotation.x = 0.0;controlsORC.object.rotation.y = 0.0;controlsORC.object.rotation.z = 0.0;if(controltype != 1 && controltype !=2){camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0;} break;\n            case 'Back': camera.position.x = -44003.546577;camera.position.y = 0;camera.position.z = 0;camera.lookAt( new THREE.Vector3( 1, 0, 0 ));if(controltype != 1 && controltype != 2){camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0;}break;\n            case 'Front': camera.position.x = 44003.546577;camera.position.y = 0;camera.position.z = 0;camera.lookAt( new THREE.Vector3( -1, 0, 0 ));if(controltype != 1 && controltype != 2){camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0;} break;\n            default : camera.position.y = 44003.546577;camera.position.x = 0;camera.position.z = 0;camera.lookAt( new THREE.Vector3( 0, -1, 0 ));if(controltype != 1 && controltype != 2){camera.up.x = 0.0;camera.up.y = 1.0;camera.up.z = 0.0;} break;\n        }\n        controltype = 1;\n\n\n        renderer.setViewport( 0, 0, window.innerWidth,  window.innerHeight  );\n\n        controlsORC.enabled = true;controlsFRC.enabled = false;\n        if (controlsDRC)\n            controlsDRC.enabled = false;\n        if (mobileAndTabletcheck()) {\n            $(\"#joystickButton\").css({display : \"none\"});\n        }\n    }\n\n    function closeMenuItems(){\n        if( $(\"#flyMenu\").css('display') == 'none' )\n            $(\"#flyMenu\").css({\"display\":\"inline\"});\n        else\n            $(\"#flyMenu\").css({\"display\":\"none\"});\n    }\n\n    //background-repeat: no-repeat;background-size: 100%;\n    function displayControllerHelp() {\n        $(\"#orbitNavHelp\").css({ \"display\": \"none\" });\n        $(\"#firstNavHelp\").css({ \"display\": \"none\" });\n        $(\"#monoStereoHelp\").css({ \"display\": \"none\" });\n        if (controltype == 1) {\n            $(\"#orbitNavHelp\").css({ \"display\": \"block\" });\n            if (mobileAndTabletcheck()) {\n                //$(\"#modalContext\").css({\"background\":\"transparent url('https://vgx.vectorworks.net/VWWebViewer v1.0.0.6/ORCHelpTouch.png')\",\"background-repeat\":\"no-repeat\",\"background-size\":\"100% 100%\"});\n            }\n            else {\n                //$(\"#modalContext\").css({\"background\":\"transparent url('https://vgx.vectorworks.net/VWWebViewer v1.0.0.6/ORCHelpDesk.png')\",\"background-repeat\":\"no-repeat\",\"background-size\":\"100% 100%\"});\n            }\n        }\n        else if (controltype == 2) {\n            $(\"#firstNavHelp\").css({ \"display\": \"block\" });\n            $(\"#firstSecondBox\").css({ \"display\": \"block\" });\n            fpcDis();\n            if (mobileAndTabletcheck()) {\n                $(\"#firstFirstBox\").css({ \"display\": \"none\" });\n                $(\"#spaceDesk\").css({ \"display\": \"none\" });\n                $(\"#spacePhone\").css({ \"display\": \"block\" });\n                $(\"#arrows1\").css({ \"display\": \"block\" });\n                $(\"#arrows2\").css({ \"display\": \"block\" });\n                //$(\"#modalContext\").css({\"background\":\"transparent url('https://vgx.vectorworks.net/VWWebViewer v1.0.0.6/FRCHelpTouch.png')\",\"background-repeat\":\"no-repeat\",\"background-size\":\"100% 100%\"});\n            }\n            else {\n                $(\"#firstFirstBox\").css({ \"display\": \"block\" });\n                $(\"#spaceDesk\").css({ \"display\": \"block\" });\n                $(\"#spacePhone\").css({ \"display\": \"none\" });\n                $(\"#arrows1\").css({ \"display\": \"none\" });\n                $(\"#arrows2\").css({ \"display\": \"none\" });\n                //$(\"#modalContext\").css({\"background\":\"transparent url('https://vgx.vectorworks.net/VWWebViewer v1.0.0.6/FRCHelpDesk.png')\",\"background-repeat\":\"no-repeat\",\"background-size\":\"100% 100%\"});\n            }\n        }\n        $(\"#helpTxt\")[0].innerHTML = \"\";\n        $(\"#helpTxt\").css({\n            \"display\": \"inline\"\n        });\n        $(\"#myModal\").modal(\"toggle\");\n        $(\"#myModal\").on(\"hidden.bs.modal\", function () {\n            fpcEn();\n        });\n    }\n\n    function displayStereoHelp(){\n        $(\"#orbitNavHelp\").css({ \"display\": \"none\" });\n        $(\"#firstNavHelp\").css({ \"display\": \"none\" });\n        $(\"#monoStereoHelp\").css({ \"display\": \"block\" });\n        fpcDis();\n        //$(\"#modalContext\").css({\"background\":\"transparent url('https://vgx.vectorworks.net/VWWebViewer v1.0.0.6/StereoMonoView.png')\",\"background-repeat\":\"no-repeat\",\"background-size\":\"100% 100%\"});\n        $(\"#helpTxt\")[0].innerHTML = \"\";\n        $(\"#helpTxt\").css({\n            \"display\": \"inline\"\n        });\n        $(\"#myModal\").modal(\"toggle\");\n        $(\"#myModal\").on(\"hidden.bs.modal\", function () {\n            fpcEn();\n        });\n    }\n\n    function displayHelp() {\n    \tif (controltype == 1 || controltype == 2)\n    \t\tdisplayControllerHelp();\n    \telse\n    \t\tdisplayStereoHelp();\n    }\n\n    function rotateVectorForYUp(vector){\n        var vectorNew = new THREE.Vector3( vector.x, vector.y, vector.z );\n        vectorNew.applyAxisAngle( new THREE.Vector3( 1, 0, 0 ),  - Math.PI / 2 );\n        vectorNew.applyAxisAngle( new THREE.Vector3( 0, 1, 0 ), Math.PI / 2 );\n        return vectorNew;\n    }\n\n    function setResetStereo(set){\n        if(set){\n            for(var x = 0 ; x < menuMesh.children.length; x++)\n                menuMesh.children[x].visible = true;\n            circleIndi.visible = true;\n            currentAction = -1;\n            previousCurrentAction = currentAction;\n            gotoNavigate = true;\n            //travel = false;\n            previousHeight = -1;\n\n        }\n        else {\n            for(var x = 0 ; x < menuMesh.children.length; x++)\n                menuMesh.children[x].visible = false;\n            circleIndi.visible = false;\n            currentAction = -1;\n            previousCurrentAction = currentAction;\n            gotoNavigate = false;\n            //travel = false;\n            previousHeight = -1;\n\n        }\n        circle3.visible = false;\n        currentAction = -1;\n        previousCurrentAction = currentAction;\n        if(myTimer)\n            clearTimeout(myTimer);\n        if(timer)\n            clearTimeout(timer);\n        timerStarted = false;\n        previousId = -1;\n        $(\"#walkSpeed\").css({\"display\":\"none\"});\n        $(\"#walkSpeed1\").css({\"display\":\"none\"});\n    }\n\n\n\n    function initializeMenu(){\n        var radius = 50;\n        var segments = 32;\n\n        menuMesh = new THREE.Mesh();\n        var mw = createMaterialForMenuGeom(0);\n        var mew = new THREE.Mesh(createMenuGeometry(radius, segments, new THREE.Vector3(60, 0, 0)),mw);\n        mew.position.copy(new THREE.Vector3(60, 0, 0));\n        mew.material.depthTest = false; mew.renderOrder = 1;mew.visible = false;\n        menuMesh.add(mew);\n\n        var ms = createMaterialForMenuGeom(1);\n        var mes = new THREE.Mesh(createMenuGeometry(radius, segments, new THREE.Vector3(180, 0, 0)),ms);\n        mes.position.copy(new THREE.Vector3(180, 0, 0));\n        mes.material.depthTest = false; mes.renderOrder = 1;mes.visible = false;\n        menuMesh.add(mes);\n\n        var msl = createMaterialForMenuGeom(3);\n        var mesl = new THREE.Mesh(createMenuGeometry(radius, segments, new THREE.Vector3(-180, 0, 0)), msl);\n        mesl.position.copy(new THREE.Vector3(-180, 0, 0));\n        mesl.material.depthTest = false; mesl.renderOrder = 1;mesl.visible = false;\n        menuMesh.add(mesl);\n\n        var mf = createMaterialForMenuGeom(2);\n        var mef = new THREE.Mesh(createMenuGeometry(radius, segments, new THREE.Vector3(-60, 0, 0)), mf);\n        mef.position.copy(new THREE.Vector3(-60, 0, 0));\n        mef.material.depthTest = false; mef.renderOrder = 1;mef.visible = false;\n        menuMesh.add(mef);\n        menuMesh.position.copy(new THREE.Vector3());\n        menuMesh.rotation.x =  -Math.PI/2;\n        menuMesh.rotation.z =  Math.PI;\n        scene.add(menuMesh);\n\n        var mindi = new THREE.MeshBasicMaterial({\n            color: 0xffffff,\n            transparent: true,\n            opacity : 1.0,\n            side: THREE.DoubleSide\n        });\n        var circleGeometryIndi = new THREE.CircleGeometry( 3, segments );\n        circleIndi = new THREE.Mesh( circleGeometryIndi, mindi );\n        circleIndi.position.copy(camera.position);\n        circleIndi.rotation.x =  -Math.PI/2;\n        circleIndi.rotation.z =  Math.PI;\n        circleIndi.material.depthTest = false;\n        circleIndi.renderOrder = 1;\n        circleIndi.visible = false;\n        scene.add( circleIndi );\n\n        var material3 = createMaterialForMenuGeom(4);\n        var circleGeometry3 = new THREE.CircleGeometry( 7, segments );\n        circle3 = new THREE.Mesh( circleGeometry3, material3 );\n        circle3.position.copy(camera.position);\n        circle3.rotation.x =  -Math.PI/2;\n        circle3.rotation.z =  Math.PI;\n        circle3.material.depthTest = false;\n        circle3.renderOrder = 1;\n        circle3.visible = false;\n        scene.add( circle3 );\n        while(imArr.length > 0){\n            imArr.pop();\n        }\n    }\n\n    function createMenuGeometry(radius, segments, translate){\n        var circleGeometry = new THREE.CircleGeometry( radius, segments );\n        return circleGeometry;\n    }\n\n    function createMaterialForMenuGeom(menuImage){\n        var Im = new THREE.Texture();\n        var image = new Image();\n        image.src = imArr[menuImage];\n        image.onload = function() {\n            Im.needsUpdate = true;\n        };\n        //var Im = THREE.ImageUtils.loadTexture(menuImage);\n        Im.image = image;\n        Im.wrapS = THREE.RepeatWrapping;\n        Im.wrapT = THREE.RepeatWrapping;\n        var material = new THREE.MeshBasicMaterial({\n            map: Im,\n            color: 0xffffff,\n            transparent: true,\n            opacity : 1.0,\n            side: THREE.DoubleSide\n        });\n        return material;\n    }\n\n\tfunction setMenuPlates(bUsingOldCode){\n\n        menuMesh.position.copy(bUsingOldCode ? camera.position : stereoCamWrapper.position).add(new THREE.Vector3(0,-350,0));\n\n        var mplanePos = new THREE.Vector3(1.0,0.0,0.0);\n        mplanePos.applyQuaternion( camera.quaternion );\n        mplanePos.normalize();\n\n        if(previousCurrentAction == 0){\n            circleIndi.position.copy(menuMesh.position).add(mplanePos.multiplyScalar(60));\n            isSelected = 1;\n        }\n        else if(previousCurrentAction == 1 || previousCurrentAction == -1){\n            circleIndi.position.copy(menuMesh.position).add(mplanePos.multiplyScalar(180));\n            isSelected = 0;\n        }\n\n        mplanePos.copy(new THREE.Vector3(0.0,-1.0,0.0));\n        mplanePos.applyQuaternion( camera.quaternion );mplanePos.y = 0.0;\n        circleIndi.position.add(mplanePos.multiplyScalar(70));\n    }\n\n    var transEnd = function(){\n\n        $('#svg circle').css({'transition': 'none'});\n        $('#svg #bar').css({'stroke-dashoffset': Math.abs(Math.PI*2*$('#svg #bar').attr(\"r\"))});\n\n    }\n\n    function changeHeight() {\n        var fh;\n        var ih;\n        if (bIsInMetric) {\n            fh = ftHt * 1000;\n            ih = inHt * 10;\n        }\n        else {\n            fh = ftHt * 12 * 2.54 * 10;\n            ih = inHt * 2.54 * 10;\n        }\n        var dif = controlsFRC.personHeight;\n        controlsFRC.personHeight = parseInt(fh + ih,10);\n        dif = controlsFRC.personHeight - dif;\n        controlsFRC.object.position.add(new THREE.Vector3(0,dif,0));\n    }\n\n    function menuRelatedSettings(bUsingOldCode) {\n\n        var vector = new THREE.Vector3( 0, 0, -1 );\n        vector.applyQuaternion( camera.quaternion );\n        var rdbar = $('#svg #bar').attr(\"r\");\n        if(vector.y < -0.80 && octCanBeBuild){\n            for(var x = 0 ; x < menuMesh.children.length; x++){\n                menuMesh.children[x].visible = true;\n            }\n            menuMesh.quaternion.copy( camera.quaternion );\n            circleIndi.quaternion.copy( camera.quaternion );\n\n            $(\"#walkSpeed\").css({\"display\":\"inline\"});\n            $(\"#walkSpeed1\").css({\"display\":\"none\"});\n\n            setMenuPlates(bUsingOldCode);\n            skipProgressRender();\n            circle3.visible = true;\n            circle3.position.copy(bUsingOldCode ? camera.position : stereoCamWrapper.position);\n            var pVec = new THREE.Vector3();\n            pVec.copy(vector);\n            if (menuMesh.children[1].id == previousId || menuMesh.children[2].id == previousId)\n                circle3.position.add(pVec.multiplyScalar(310));\n            else\n                circle3.position.add(pVec.multiplyScalar(325));\n            currentAction = -1;\n\n            var raycasterSt = new THREE.Raycaster(bUsingOldCode ? camera.position : stereoCamWrapper.position,vector,camera.near,camera.far);\n\n            raycasterSt.ray.origin.copy( bUsingOldCode ? camera.position : stereoCamWrapper.position );\n            raycasterSt.ray.direction.copy( vector );\n            intersectionsSt = raycasterSt.intersectObjects( menuMesh.children );\n\n            if(intersectionsSt) {\n                if( intersectionsSt.length > 0) {\n                    if(previousId != intersectionsSt[ 0 ].object.id) {\n                        previousId = intersectionsSt[ 0 ].object.id;\n                        $('#svg').css({ \"display\":\"inline\"});\n                        $('#svg circle').css({'transition': 'stroke-dashoffset 0.7s linear'});\n                        if(myTimer)\n                            clearTimeout(myTimer);\n                        if((previousId == menuMesh.children[2].id) || (previousId == menuMesh.children[3].id)){\n                            $('#svg circle').css({'transition': 'stroke-dashoffset 0.3s linear'});\n                            myTimer = setTimeout(timeOutFunction, 350);\n                        }\n                        else\n                            myTimer = setTimeout(timeOutFunction, 800);\n                        if (!skipProgressRender())\n                            setTimeout(function(){$('#svg #bar').css({'stroke-dashoffset': 1.10});},10);\n                        setProgressData(intersectionsSt[ 0 ].object.position);\n                        timerStarted = true;\n                    }\n                    else {\n                        setProgressData(intersectionsSt[ 0 ].object.position);\n                        timerStarted = true;\n                    }\n                }\n                else{\n\n                    $('#svg').css({ \"display\":\"none\"});\n                    $('#svg #bar').css({'stroke-dashoffset': Math.abs(Math.PI*2*rdbar)});\n                    //$('#svg #bar1').css({'stroke-dashoffset': Math.abs(Math.PI*2*rdbar)});\n                    if(myTimer)\n                        clearTimeout(myTimer);\n                    previousId = -1;\n                    timerStarted = false;\n                }\n            }\n            else{\n                $('#svg').css({ \"display\":\"none\"});\n                $('#svg #bar').css({'stroke-dashoffset': Math.abs(Math.PI*2*rdbar)});\n               // $('#svg #bar1').css({'stroke-dashoffset': Math.abs(Math.PI*2*rdbar)});\n                if(myTimer)\n                    clearTimeout(myTimer);\n                previousId = -1;\n                timerStarted = false;\n            }\n        }\n        else{\n            for(var x = 0 ; x < menuMesh.children.length; x++)\n                menuMesh.children[x].visible = false;\n            $('#svg #bar').css({'stroke-dashoffset': Math.abs(Math.PI*2*rdbar)});\n            //$('#svg #bar1').css({'stroke-dashoffset': Math.abs(Math.PI*2*rdbar)});\n            $(\"#walkSpeed\").css({\"display\":\"none\"});\n            $(\"#walkSpeed1\").css({\"display\":\"none\"});\n            $('#svg').css({ \"display\":\"none\"});\n            circle3.visible = false;\n            currentAction = previousCurrentAction;\n        }\n    }\n\n    function setProgressData(position){\n\n        var mplanePos = new THREE.Vector3(1.0,0.0,0.0);\n        mplanePos.applyQuaternion( camera.quaternion );\n\n        var canvas = renderer.domElement;\n        mplanePos.multiplyScalar(position.x);\n\n        var pos = new THREE.Vector3();\n        pos.copy(mplanePos);\n        pos.add(menuMesh.position);\n\n        pos.project( camera );\n        pos.x = Math.round( (   pos.x + 1 ) * canvas.width  / (2 * window.devicePixelRatio) ),\n        pos.y = Math.round( ( - pos.y + 1 ) * canvas.height / (2 * window.devicePixelRatio) );\n        pos.z = 0;\n\n        $('#svg #bar').attr(\"cx\", pos.x);$('#svg #bar').attr(\"cy\", pos.y );\n        $('#svg #barInner').attr(\"cx\", pos.x );$('#svg #barInner').attr(\"cy\", pos.y );\n    }\n\n    function timeOutFunction() {\n\n        if(timerStarted == true){\n            for(var x = 0 ; x < menuMesh.children.length; x++) {\n                if(menuMesh.children[x].id == previousId){\n                    switch(x)\n                    {\n                        case 0:\n                            currentAction = x;\n                            previousCurrentAction = currentAction;\n                            mouseHasMoved = false;\n                            break;\n                        case 1:\n                            currentAction = x;\n                            previousCurrentAction = currentAction;\n                            break;\n                        case 2:\n                            if (stereoSpeedScale > 3) { stereoSpeedScale -= 1; } $(\"#walkSpeedText\").text(resources[\"#360 Controls App\"][\"walk\"] + stereoSpeedScale.toString()); $(\"#walkSpeedText1\").text(resources[\"#360 Controls App\"][\"walk\"] + stereoSpeedScale.toString());\n                            break;\n                        case 3:\n                            if (stereoSpeedScale < 30) { stereoSpeedScale += 1; } $(\"#walkSpeedText\").text(resources[\"#360 Controls App\"][\"walk\"] + stereoSpeedScale.toString()); $(\"#walkSpeedText1\").text(resources[\"#360 Controls App\"][\"walk\"] + stereoSpeedScale.toString());\n                            break;\n                        default: break;\n\n                    }\n                    break;\n                }\n            }\n        }\n\n        $('#svg').css({ \"display\":\"none\"});\n        var object = scene.getObjectById(previousId,true);\n        previousId = -1;\n        timerStarted = false;\n    }\n\n\n    var navigateCamera = (function() {\n\n\t\tthis.travel = true;\n\t\tthis.currentDirection = new THREE.Vector3(0,0,1);\n\t\tthis.currentPosition = new THREE.Vector3();\n\t\tthis.fpcCollisionDistance = -1;\n\t\tthis.fpcCollisionSideDistanceMin = 3000;\n\t\tvar self = this;\n\n\t\tfunction detectCollisionInFront(dir){\n        if(!octCanBeBuild)\n\t\t\t\treturn 0;\n\t\tif(!manager._modelInfo.navigationMeshCreated) {\n\t\t\tShowPopup(resources[\"#notdone\"]);\n\t\t\t\treturn 0;\n\t\t}\n\t\t\t//dir.y = 0.0;\n\t\t\t//dir.normalize();\n\n\t\t\tif (bIsCollisionOn)\n\t\t\t\treturn 3;\n\t\t\tif(self.currentDirection.angleTo(dir) < Math.PI/9 ) {\n\t\t\t\tif(self.fpcCollisionDistance > 500)\n\t\t\t\t\treturn 2;\n\t\t\t\tif(self.currentPosition.distanceTo(manager._camera.position) < 0.1)\n\t\t\t\t\treturn 0;\n\t\t\t}\n\n\n\t\t\tself.currentPosition.copy(manager._camera.position);\n\t\t\tself.currentPosition.add(stereoCamVector);\n\t\t\tself.currentDirection.copy(dir);\n        var rayCasterLookAt = new THREE.Raycaster(new THREE.Vector3(),new THREE.Vector3(),0,camera.far);\n        rayCasterLookAt.setFromCamera ( new THREE.Vector2(), camera );\n\t\t\trayCasterLookAt.ray.direction.copy(self.currentDirection);\n\t\t\tvar octreeObjectsS = [];\n\n\t\t\tfor(var tx = 0 ; tx < manager._octreeList.length; tx++ ){\n\t\t\t\tvar octreeObjectsST = manager._octreeList[tx].search( rayCasterLookAt.ray.origin, 20000, true, rayCasterLookAt.ray.direction );\n\n\t\t\t\tfor(var tx1 = 0 ; tx1 < octreeObjectsST.length; tx1++ ){\n\t\t\t\t\toctreeObjectsS.push(octreeObjectsST[tx1]);\n\t\t\t\t}\n\t\t\t}\n\n\n\t\t\tvar intersectNavCam = rayCasterLookAt.intersectOctreeObjects(octreeObjectsS);\n\t\t\tintersectNavCam.sort(function(a,b){return a.distance - b.distance});\n\t\t\tif(intersectNavCam.length > 0) {\n\t\t\t\tif(intersectNavCam[0].distance < 500) {\n\t\t\t\t\tif(!intersectNavCam[0].object.material.transparent){\n\t\t\t\t\t\treturn 1;\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\telse {\n\t\t\t\t\tif(intersectNavCam[0].object.material.transparent)\n\t\t\t\t\t\tself.fpcCollisionDistance = (intersectNavCam.length > 1)?(intersectNavCam[1].distance):20000;\n\t\t\t\t\telse\n\t\t\t\t\t\tself.fpcCollisionDistance = (intersectNavCam.length > 0)?(intersectNavCam[0].distance):20000;\n\t\t\t\t}\n\t\t\t}\n\t\t\telse\n\t\t\t\tself.fpcCollisionDistance = 20000;\n\n\t\t\treturn 4;\n\t\t};\n\n\n\t\tfunction detectCollisionInDown(dir) {\n\t\t\tif(timer)\n\t\t\t\tclearTimeout(timer);\n\n\t\t\tvar direction = new THREE.Vector3().copy(dir === undefined ? manager._camera.getWorldDirection() : dir);\n\t\t\tdirection.y = 0.0;\n\t\t\tvar canBeMoved = detectCollisionInFront(direction);\n\n\t\t\tif(canBeMoved == 0 || canBeMoved == 1) {// Octree not build or camera not changed at all or if object in front is opaque\n\t\t\t\tself.travel = false;\n\t\t\t}\n\t\t\telse {\n\t\t\t\tvar travelV = true;\n\n        var camPos = new THREE.Vector3();\n\t\t\t\tcamPos.copy(stereoCamVector).add(direction.multiplyScalar(300));\n        var rayCasterDown = new THREE.Raycaster(camPos,new THREE.Vector3(0,-1,0),0,camera.far);\n        rayCasterDown.ray.origin.copy(camPos);\n        rayCasterDown.ray.direction.copy(new THREE.Vector3(0,-1,0));\n        var octreeObjectsDown = [];\n\n        for(var tx = 0 ; tx < manager._octreeList.length; tx++ ){\n            var octreeObjectsDownL = manager._octreeList[tx].search( rayCasterDown.ray.origin, 3000, true, rayCasterDown.ray.direction );\n            for(var tx1 = 0 ; tx1 < octreeObjectsDownL.length; tx1++ ){\n                octreeObjectsDown.push(octreeObjectsDownL[tx1]);\n            }\n        }\n\n        var intersections1 = rayCasterDown.intersectOctreeObjects(octreeObjectsDown);\n        intersections1.sort(function(a,b){return a.distance - b.distance});\n\n        if(intersections1.length > 0)\n        {\n            if(previousHeight === -1){\n                if(intersections1[0].distance != 1750){\n                    previousHeight = 1750;\n                    stereoCamVector.y = stereoCamVector.y - (intersections1[0].distance - 1750);\n                    previousCameraPos = stereoCamVector.y;\n                }\n                else\n                    previousHeight = intersections1[0].distance;\n            }\n            else {\n                var diff = Math.abs(intersections1[0].distance - previousHeight);\n                if(diff > 0 && diff < 600){\n                    if(intersections1[0].distance > previousHeight)\n                        stereoCamVector.y -= Math.abs(intersections1[0].distance - previousHeight);\n                    else\n                        stereoCamVector.y += Math.abs(intersections1[0].distance - previousHeight);\n                    previousCameraPos = stereoCamVector.y;\n                }\n                else if(diff > 600)\n                    travelV = false;\n\n            }\n        }\n        else {\n            stereoCamVector.y = previousCameraPos;\n            travelV = false;\n        }\n\n\t\t\t\tswitch(canBeMoved){\n\t\t\t\t\tcase 2:\n\t\t\t\t\tcase 3:\n\t\t\t\t\tcase 4:\n\t\t\t\t\t\tif(travelV)\n\t\t\t\t\t\t\tself.travel = true;\n            else\n\t\t\t\t\t\t\tself.travel = false;\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tdefault :self.travel = false;\n        }\n        }\n\n\t\t\tif(self.travel)\n\t\t\t\ttimer = setTimeout(function() {gotoNavigate = true;},((self.fpcCollisionDistance - 500)>(30*stereoSpeedScale))?500:(self.fpcCollisionDistance - 500)/(30*stereoSpeedScale)/500);\n\t\t\telse\n\t\t\t\ttimer = setTimeout(function() {gotoNavigate = true;},500);\n\t\t};\n\n\n\t\treturn function(dir){\n\t\t\tif(gotoNavigate)\n\t\t\t\tdetectCollisionInDown(dir);\n\t\t\tgotoNavigate = false;\n\t\t\tif(self.travel){\n\t\t\t\tvar vector = dir === undefined ? new THREE.Vector3( 0, 0, -1 ) : dir;\n\t\t\t\tvector.applyQuaternion( camera.quaternion );\n\t\t\t\tvector.y = 0.0;\n\t\t\t\tstereoCamVector.add(vector.multiplyScalar(stereoSpeedScale));\n\t\t\t\tself.fpcCollisionDistance -= stereoSpeedScale;\n                return true;\n             }\n             else\n                return false;\n\t\t};\n    })();\n\n\nTHREE.SSAOShader = {\n\n    uniforms: {\n\n        \"u_IsAOOrFilter\": \t{ type: \"i\", value: 0 },\n        \"tDiffuse\": \t\t{ type: \"t\", value: null },\n        \"u_ScreenRes\":\t\t{ type: \"v2\", value: new THREE.Vector2( 512, 512 ) },\n        \"u_InvProj\": \t\t{ type: \"m4\", value: null },\n        \"u_UVBound\": \t\t{ type: \"v4\", value: new THREE.Vector4( 0,0,1,1 ) },\n        \"u_NearFar\":\t\t{ type: \"v2\", value: new THREE.Vector2( 0, 100 ) },\n        \"u_TanHalfFOV\": \t{ type: \"f\", value: 0.5 },\n        \"u_Viewport\":\t\t{ type: \"v4\", value: new THREE.Vector4( 0,0,1,1 ) },\n        \"u_DepthTex\":\t\t{ type: \"t\", value: null },\n        \"u_AOInput\":\t\t{ type: \"v2\", value: new THREE.Vector2( 512, 512 ) },\n        \"u_AOTex\":\t\t\t{ type: \"t\", value: null },\n        \"u_VertexIDs\":      { type: \"t\", value: null }\n    },\n\n    vertexShader: [\n\n        \"varying vec2 vUv;\",\n        \"varying vec3 vNormal;\",\n\n        \"void main() {\",\n            //uv Attribute set by THREE.js\n            \"vUv = uv;\",                                                                \n            \n            //normal Attribute set by THREE.js (We are not using this since this is a postprocessing shader the normals send it by THREEjs is always (0,0,1) We create the normal map and send it here under u_VertexIDs)\n            \"vNormal = normalMatrix*vec4(normal,1.0).xyz;\",                             \n            \n            \"gl_Position = projectionMatrix * modelViewMatrix * vec4( position, 1.0 );\",\n        \"}\"\n\n    ].join( \"\\n\" ),\n\n    fragmentShader: [\n        \"precision highp float;\",       // High precision for floats.\n        \"precision highp int;\",\n\n        \"#extension GL_OES_standard_derivatives : enable\",\n        \"#define kOrthoVersion 0\", \n        \"#define kTile 0\",\n\n        \"uniform int u_IsAOOrFilter;\",\n        \"uniform sampler2D tDiffuse;\", // u_SrcColor This is by default provided by the EffectComposer as an input.\n        \"uniform vec2 u_ScreenRes;\",\n        \"uniform mat4 u_InvProj;\",\n        \"uniform vec4 u_UVBound;\", // vec4( vec2(low_bound).xy , vec2(high_bound).xy ).\n        \"uniform vec2  u_NearFar;\",\n        \"uniform float u_TanHalfFOV;\",\n        \"uniform vec4  u_Viewport;\",\n        \"uniform sampler2D u_DepthTex;\",\n        \"uniform sampler2D u_VertexIDs;\",\n        \"uniform vec2 u_AOInput;\", // x = radius, y = sigma(strength).\n        \"uniform sampler2D u_AOTex;\",\n\n        \"varying vec2 vUv;\",\n        \"varying vec3 vNormal;\",\n        \"#define\tu_sigma\t\t\t2.0\",\t// bilateral filter gaussian coefficient.\n\n        // QUALITY PARAMETERS\n\n        \"#define NUM_SAMPLES       11\",      // 12  24  32\n        \"#define NUM_SPIRAL_TURNS   3\",       //  2   4   6  //< I think it's better if this is *not* a sub-multiple of NUM_SAMPLES\n        \"#define TWOPI 6.2831853\",\n        \"const float invNumSamples = 1.0 / float(NUM_SAMPLES);\",\n\t\t\n\t\t\"const float UnpackDownscale = 255. / 256.;\",\n\t\t\"const vec3 PackFactors = vec3( 256. * 256. * 256., 256. * 256.,  256. );\",\n\t\t\"vec4 UnpackFactors = UnpackDownscale / vec4( PackFactors, 1. );\",\n\t\t\n\t\t\"float unpackRGBAToDepth( const in vec4 v ) {\",\n\t\t\t\"return dot( v, UnpackFactors );\",\n\t\t\"}\",\n\t\t\n        \"float linearDepth(float d, float near, float far)\",\n        \"{\",\n            \"return - near*far / ((near-far)*d+far);\",\n        \"}\",\n\n\n        \"vec3 GetViewPos(vec2 uv, out float outZ)\",\n        \"{\",\n            \"uv = clamp(uv, vec2(0.0, 0.0), vec2(1.0, 1.0));\",\n            \"float d = texture2D(u_DepthTex, uv).x;\",\n            \"float near = u_NearFar.x;\",\n            \"float far = u_NearFar.y;\",\n            \"outZ = linearDepth(d, near, far);\",\n            \"uv = 2.0*uv-1.0;\", //< Convert [0,1] => [-1,1]\n            \"vec2 UVtoViewCoeff = vec2(u_TanHalfFOV * float(u_ScreenRes.x) * float((vec2(1.0) / vec2(u_ScreenRes)).y), u_TanHalfFOV);\",\n            \"uv = -UVtoViewCoeff*uv;\",\n            \"return vec3(uv*outZ,outZ);\",\n        \"}\",\n\n\n        \"vec2 tapLocation(int sampleNumber, float spinAngle, out float ssR)\",\n        \"{\",\n            \"float alpha = (float(sampleNumber) + 0.5) * invNumSamples;\",\n            \"float angle = alpha * (float(NUM_SPIRAL_TURNS) * TWOPI) + spinAngle;\",\n            \"ssR = alpha;\",\n            \"return vec2(cos(angle), sin(angle));\",\n        \"}\",\n\n        \"float rand(vec2 co)\",\n        \"{\",\n            \"const float a = 12.9898;\",\n            \"const float b = 78.233;\",\n            \"const float c = 43758.5453;\",\n            \"float dt = dot(co.xy ,vec2(a,b));\",\n            \"float sn = mod(dt, 3.14);\",\n            \"return fract(sin(sn) * c);\",\n        \"}\",\n\n        \"bool IsOutsideBoundary(vec2 aoTexS)\",\n        \"{\",\n            \"vec2 outsideUpperBound = step( vec2(1.0,1.0) , aoTexS);\",\n            \"vec2 outsideLowerBound = vec2(1.0,1.0) - step( vec2(0.0,0.0) , aoTexS);\",\n            \"if ( outsideUpperBound.x + outsideUpperBound.y + outsideLowerBound.x + outsideLowerBound.y >= 1.0 )\",\n                \"return true;\",\n            \"return false;\",\n        \"}\",\n\n\n        \"float alchemy_ao(float aoRad, float aoSigma, out float outZ, out vec3 outNormal)\",\n        \"{\",\n            \"vec2 aoTexCoord = gl_FragCoord.xy / vec2(u_ScreenRes.x,u_ScreenRes.y);\",\n            \n            // Alchemy parameters r, beta, sigma, epsilon  and good defaults\n            //const float aoRad = 35.0;       // 35.0;\n\n            \"float aoBias = 0.001;\",\n            //const float aoSigma = 15;       // 15\n            \"const float aoEp = 0.01;\",        // 0.01\n\n            // UV of current fragment in full-screen quad, [0,1]\n            \"vec3 aoC = GetViewPos(aoTexCoord, outZ);\", //< View coords of current fragment's position\n            \"float uvDiskRadius;\",\n            \"uvDiskRadius = 0.5/u_TanHalfFOV*aoRad/aoC.z;\",\n            \"float randPatternRotAngle = rand(gl_FragCoord.xy)*TWOPI;\",\n            \"float ao = 0.0;\",\n            \"int nActualSamples = 0;\",\n            \n            // Normal either calcuated or taken from the u_VertexIds. If calculated we try to find an averaged out normal based on the surrounding normal values. \n\t\t\t\n            //\"vec3 reconstructed_N = texture2D(u_VertexIDs, aoTexCoord).xyz;\",\n\t\t\t// UnComment following if normal is to be calculated in shader and comment above line.\n            \"vec3 reconstructed_N=normalize(cross(dFdx(aoC),dFdy(aoC)));\",\n                        \n            \"vec3 avgReconstructedNormal = reconstructed_N;\",\n            \n            // UnComment following if normal is to be calculated in shader. \n            \"for (float i=0.0; i<5.0; i++)\",\n            \"for (float j=0.0; j<5.0; j++) {\",\n                \"float garbageZ;\",\n                \"vec3 aoQ = GetViewPos(vUv + vec2(1.0/u_ScreenRes.x, 1.0/u_ScreenRes.y) * vec2(i-1.0,j-1.0) , garbageZ);\",\n                \"avgReconstructedNormal += normalize(cross(dFdx(aoQ),dFdy(aoQ)));\",\n            \"}\",\n\n\t\t\t\"avgReconstructedNormal = normalize(avgReconstructedNormal);\",\n\n            \"outNormal = avgReconstructedNormal;\", //< View coords of current fragment's normal\n            \"for (int i = 0 ; i < NUM_SAMPLES ; ++i)\",\n            \"{\",\n                \"float ssR, garbageZ;\",\n                \"vec2 aoUnitOffset = tapLocation(i, randPatternRotAngle, ssR);\",\n                \"ssR *= uvDiskRadius;\",\n                \"vec2 aoTexS = aoTexCoord + ssR*aoUnitOffset;\",\n                \"vec3 aoQ = GetViewPos(aoTexS, garbageZ);\",\n                // When the view position is very closer than the AO size, it shows strange shading.\n                \"if ( IsOutsideBoundary(aoTexS) )\",\n                    \"continue;\",\n                \"vec3 aoV = aoQ - aoC;\",\n                \"float aoVv = dot(aoV, aoV);\",\n                \"float aoVn = dot(aoV, outNormal);\",\n                \"aoVn = step( aoRad*0.05, aoVn) * aoVn;\", //< Do not consider as occluding fragments near 90deg to normal\n                \"ao += max(0.0,aoVn + aoC.z*aoBias)/(aoVv+aoEp);\",   //< Bias is optional. Makes faraway crevices less dark\n                \"nActualSamples ++;\",\n            \"}\",\n\n            \"ao = max(0.0,1.0 - 2.0*aoSigma*ao/float(nActualSamples));\", // XXX: What if nActualSamples is 0?\n            // At this point ao is in [0,1] where 0 is dark\n            // This rescaling darkens and spreads the values\n            \"ao *= ao;\", // Alchemy : k = 4.\n            \"ao *= ao;\",\n            \"ao = ao * .5 + .5;\", //< This spreads nicely .7 + .3   also .5+.5  (Hernan's invention)\n            \"return ao;\",\n        \"}\",\n        \n        \n       \"void main()\",\n        \"{\",\n            \"vec2 aoTexCoord = gl_FragCoord.xy / vec2(u_ScreenRes.x,u_ScreenRes.y);\",\n            \"float linearDepth;\",\n            \"vec3 normal;\",\n            \"float ao = alchemy_ao( u_AOInput.x, u_AOInput.y, linearDepth, normal );\",   // Lower second arg if combining more factors\n\n            //\"ao = mix(ao-1.0, 1.0-ao, step(0.0, normal.z) );\", // flip the AO sign. so use it to reconstruct normal z in bilateral filtering.\n            //\"gl_FragData[0] = vec4(ao, linearDepth, normal.x, normal.y);\",\t\n            \n            \"vec3 color = texture2D(tDiffuse, aoTexCoord).xyz;\",    // AO mixed with the actual actual source\n            \"gl_FragData[0] = vec4(color*ao,1.0);\",\n           // \"gl_FragData[0] = vec4(normalize(vec3(0,0,0.0000000000000000000001)),1);\", //Precision testing \n            //\"gl_FragData[0] = vec4(normal,1);\",                   // Normals calculated or taken from MAP (depending upon the above choice)\n            \n            \n\t\t   // \"gl_FragData[0] = vec4(vec3(linearDepth),1);\",\n            \n           \n           \n            // Linear depth is necessary because the frustum size can vary a lot.\n            // DEBUGGING: DRAW AO CHANNEL ONLY\n            //gl_FragData[0] = vec4(vec3(ao),1);\n\n            // DEBUGGING: USE COLOR TO BLEND OR DO SOMETHING ELSE\n            //vec3 color = texture2D(u_SrcColor, aoTexCoord).xyz;\t\n            //gl_FragData[0] = vec4(color*ao,1);\n\n            // DEBUGGING: DRAW DEPTH\t\n            //float dep = texture2D(u_DepthTex,aoTexCoord).x;\n            //gl_FragData[0] = vec4(dep,dep,dep,1);\n\n            // DEBUGGING: COMPARE REAL NORMALS WITH DEPTH-BUFFER-RECONSTRUCTED NORMALS\n            //vec3 reconstructed_N = normalize(cross(dFdx(aoC),dFdy(aoC)));\n            //float diff = dot( reconstructed_N, aoN_C);\n            //gl_FragData[0] = vec4(diff, diff, diff, 1);\n        \"}\",\n\n    ].join( \"\\n\" )\n\n};\n\n/**\n * @author alteredq / http://alteredqualia.com/\n *\n * Screen-space ambient occlusion shader\n * - ported from\n *   SSAO GLSL shader v1.2\n *   assembled by Martins Upitis (martinsh) (http://devlog-martinsh.blogspot.com)\n *   original technique is made by ArKano22 (http://www.gamedev.net/topic/550699-ssao-no-halo-artifacts/)\n * - modifications\n * - modified to use RGBA packed depth texture (use clear color 1,1,1,1 for depth pass)\n * - refactoring and optimizations\n */\n\nTHREE.SSAOShaderBilateral = {\n\n\tuniforms: {\n\n\t\t\n\t\t\"tDiffuse\": \t\t{ type: \"t\", value: null },\n\t\t\"u_ScreenRes\":\t\t{ type: \"v2\", value: new THREE.Vector2( 512, 512 ) },\n\t\t\"u_InvProj\": \t\t{ type: \"m4\", value: null },\n\t\t\"u_UVBound\": \t\t{ type: \"v4\", value: new THREE.Vector4( 0,0,1,1 ) },\n\t\t\"u_NearFar\":\t\t{ type: \"v2\", value: new THREE.Vector2( 0, 100 ) },\n\t\t\"u_TanHalfFOV\": \t{ type: \"f\", value: 0.5 },\n\t\t\"u_Viewport\":\t\t{ type: \"v4\", value: new THREE.Vector4( 0,0,1,1 ) },\n\t\t\"u_DepthTex\":\t\t{ type: \"t\", value: null },\n\t\t\"u_AOInput\":\t\t{ type: \"v2\", value: new THREE.Vector2( 512, 512 ) },\n\t\t\"u_VertexIDs\":         { type: \"t\", value: null }\n\t},\n\n\tvertexShader: [\n\n\t\t\"varying vec2 vUv;\",\n                \"varying vec3 vNormal;\",\n\n\t\t\"void main() {\",\n\n\t\t\t\"vUv = uv;\",\n                        \"vNormal = normalMatrix*vec4(normal,1.0).xyz;\",\n\t\t\t\"gl_Position = projectionMatrix * modelViewMatrix * vec4( position, 1.0 );\",\n\n\t\t\"}\"\n\n\t].join( \"\\n\" ),\n\n\tfragmentShader: [\n                'precision highp float;',\n\t\t\"#extension GL_OES_standard_derivatives : enable\",\n                \"#define kOrthoVersion 0\",\n                \"#define kTile 0\",\n\n               \n\n                \"uniform sampler2D u_VertexIDs;\",\n                \"uniform vec2 u_ScreenRes;\",\n                \"uniform mat4 u_InvProj;\",\n                \"uniform vec4 u_UVBound;\",\n                \"uniform vec2  u_NearFar;\",\n                \"uniform float u_TanHalfFOV;\",\n                \"uniform vec4  u_Viewport;\",\n                \"uniform sampler2D u_DepthTex;\",\n\n                \"uniform vec2 u_AOInput;\", // x = radius, y = sigma(strength).\n\n                \"#define\tu_sigma\t\t\t2.0\",\t// bilateral filter gaussian coefficient.\n\n                \"uniform sampler2D tDiffuse;\",\n\n                \"#define BILATERAL_SAMPLES   18\",\n\n\n                // These are the Poisson Disk Samples : Kernel size 10.\n                \"vec2 poisson35[BILATERAL_SAMPLES];\",\n\n                \"void InitPoisson35()\",\n                \"{\",\n                        //\n                        // GL ES 2.0 doesn't allow const array initialization... :(\n                        //\n                        \"poisson35[0] = vec2( -0.717464  * 5.0 , -0.551712   * 5.0);\",\n                        \"poisson35[1] = vec2( -0.3925666 * 5.0 , -0.9109293  * 5.0);\",\n                        \"poisson35[2] = vec2( -0.6437587 * 5.0 , -0.1092545  * 5.0);\",\n                        \"poisson35[3] = vec2( -0.2152211 * 5.0 , -0.4443597  * 5.0);\",\n                        \"poisson35[4] = vec2( 0.3557019  * 5.0 , -0.5133379  * 5.0);\",\n                        \"poisson35[5] = vec2( 0.08443579 * 5.0 , -0.1805867  * 5.0);\",\n                        \"poisson35[6] = vec2( 0.1583342  * 5.0 , -0.8591337  * 5.0);\",\n                        \"poisson35[7] = vec2( 0.1509504  * 5.0 , 0.2373314   * 5.0);\",\n                        \"poisson35[8] = vec2( -0.8411611 * 5.0 , 0.2474918   * 5.0);\",\n                        \"poisson35[9] = vec2( -0.5672057 * 5.0 , 0.6524203   * 5.0);\",\n                        \"poisson35[10] = vec2( 0.07155065 * 5.0 , 0.8577791   * 5.0);\",\n                        \"poisson35[11] = vec2( 0.7180662  * 5.0 , 0.304107    * 5.0);\",\n                        \"poisson35[12] = vec2( 0.5590702  * 5.0 , -0.05804106 * 5.0);\",\n                        \"poisson35[13] = vec2( 0.4947674  * 5.0 , 0.753773    * 5.0);\",\n                        \"poisson35[14] = vec2( -0.1863001 * 5.0 , 0.5235718   * 5.0);\",\n                        \"poisson35[15] = vec2( -0.2546171 * 5.0 , 0.06398818  * 5.0);\",\n                        \"poisson35[16] = vec2( 0.7375152  * 5.0 , -0.4275172  * 5.0);\",\n                        \"poisson35[17] = vec2( 0.9661041  * 5.0 , -0.04680404 * 5.0);\",\n\n                \"}\",\n\n                // QUALITY PARAMETERS\n                \"#if kTile == 1\",\n                \"#define NUM_SAMPLES       32\",\n                \"#else\",\n                \"#define NUM_SAMPLES       11\",       // 12  24  32\n                \"#endif\",\n                \"#define NUM_SPIRAL_TURNS   3\",       //  2   4   6  //< I think it's better if this is *not* a sub-multiple of NUM_SAMPLES\n\n                \"#define TWOPI 6.2831853\",\n\n                \"const float invNumSamples = 1.0 / float(NUM_SAMPLES);\",\n            \n              \n\n                \"float linearDepth(float d, float near, float far)\",\n                \"{\",\n                        \"return - near*far / ((near-far)*d+far);\",\n                \"}\",\n\n\n                \"void ExtractNormalAO(vec2 coord, out vec3 outNormal, out float outAO, out float outLinearDepth)\",\n                \"{\",\n                       \n                        \"vec4 AO_depth_normal = texture2D(tDiffuse, coord);\", // (during bilateral filtering) AO Tex format = [ao value, linear depth, normal.x, normal.y].\n                        \"vec2 AOandNormalZ = vec2(AO_depth_normal.x, sqrt(1.0 - AO_depth_normal.z * AO_depth_normal.z - AO_depth_normal.w * AO_depth_normal.w) );\",\n\n                        // Reconstructing normal_z from normal_x and y. z = sqrt(1 - x^2 + y^2). However, z's sign is not known.\n                        // Since AO value is always [0, 1]. I pass AO as negative if normal_z is negative. So I can reconstruct the sign of normal as well as the absolute value.\n                        // For example, ao == -0.3, it means that normal.z was negative so I flipped the sign of ao in ambient occlusion pass. so I know normal.z is negative.\n                        \"AOandNormalZ = mix(-AOandNormalZ, AOandNormalZ, step(0.0, AOandNormalZ.x) );\",\n                        \"outNormal = vec3(AO_depth_normal.zw, AOandNormalZ.y);\",\n                        \"outAO = AOandNormalZ.x;\",\n                        \"outLinearDepth = AO_depth_normal.y;\",\n                \"}\",\n\n                \"float bilateralFilter(float aoSize, out float outZ, out vec3 outNormal) {\",\n                        \"vec2 aoTexCoord = gl_FragCoord.xy / vec2(u_ScreenRes.x,u_ScreenRes.y);\",\n                        \"float blurredColor = 0.0;\",\n                        \"vec2 neighbor_pos;\",\n                        \"float sumCoeff = 0.0;\",\n                        \"float coefG, coefZ, coefN, finalCoef;\",\n                        \"float distSquared;\",\n\n                        \"float aoC;\",\n                        \"float neighborAO, neighborDepth;\",\n                        \"vec3 neighborNormal;\",\n                        \"ExtractNormalAO(aoTexCoord, outNormal, aoC, outZ);\",\n\n                        \"float normalizeG =  1.0;\", //1.0 / (sqrt(2 * 3.14159265) * u_sigma);\n                        \"const float epsilon = 0.001;\",\n\n                        \"for(int i = 0 ; i < BILATERAL_SAMPLES ; i++) {\",\n\n                                \"vec2 noiseSample = poisson35[i];\", //< In Pixels\n                                \"neighbor_pos = aoTexCoord + noiseSample * (vec2(1.0) / vec2(u_ScreenRes));\", //< neighbor_pos in [0,1]\n                                \"distSquared = noiseSample.x * noiseSample.x + noiseSample.y * noiseSample.y;\", //< Pixels^2\n                                \"coefG = exp(-0.5 * float(distSquared) / (u_sigma * u_sigma));\", //gaussianCoef( i, j );\n\n                                \"ExtractNormalAO(neighbor_pos, neighborNormal, neighborAO, neighborDepth);\",\n\n                                \"float depthDiff = min(1.0, abs(outZ - neighborDepth) * (0.3 / aoSize) );\",\n                                \"float normalDiff = 1.0 - max(0.0, dot(neighborNormal, outNormal));\",\n\n                                \"coefZ = 1.0 / (epsilon + depthDiff);\",\n                                \"coefN = 1.0 / (epsilon + normalDiff);\",\n\n                                \"finalCoef = coefG * coefZ * coefN;\",\n                                \"sumCoeff += finalCoef;\",\n                                \"blurredColor += finalCoef * neighborAO;\",\n                        \"}\",\n\n                        \"return blurredColor / sumCoeff * normalizeG;\",\n                \"}\",\n\n\n                \"void main()\",\n                \"{\",\n                        \"InitPoisson35();\",\n                        \"vec2 aoTexCoord = gl_FragCoord.xy / vec2(u_ScreenRes.x,u_ScreenRes.y);\",\n\n                        \"float linearDepth;\",\n                        \"vec3 normal;\",\n                        \"float blurredAO = bilateralFilter(u_AOInput.x, linearDepth, normal);\",\n\n                        //\"blurredAO = mix(-blurredAO, blurredAO, step(0.0, normal.z) );\",\n                        //\"gl_FragData[0] = vec4(blurredAO, linearDepth, normal.x, normal.y);\",\n                        \"vec3 color = texture2D(tDiffuse, aoTexCoord).xyz;\",\n                        \"gl_FragData[0] = vec4(color*(blurredAO),1);\",\n                        //gl_FragData[0] = texture2D(tDiffuse, aoTexCoord);\n\n                        // DEBUGGING: DRAW AO CHANNEL ONLY\n                        //gl_FragData[0] = vec4(vec3(ao),1);\n\n                        // DEBUGGING: USE COLOR TO BLEND OR DO SOMETHING ELSE\n                        //vec3 color = texture2D(u_SrcColor, aoTexCoord).xyz;\t\n                        //gl_FragData[0] = vec4(color*ao,1);\n\n                        // DEBUGGING: DRAW DEPTH\t\n                        //float dep = texture2D(u_DepthTex,aoTexCoord).x;\n                        //gl_FragData[0] = vec4(dep,dep,dep,1);\n\n                        // DEBUGGING: COMPARE REAL NORMALS WITH DEPTH-BUFFER-RECONSTRUCTED NORMALS\n                        //vec3 reconstructed_N = normalize(cross(dFdx(aoC),dFdy(aoC)));\n                        //float diff = dot( reconstructed_N, aoN_C);\n                        //gl_FragData[0] = vec4(diff, diff, diff, 1);\n                \"}\",\n\n\t].join( \"\\n\" )\n\n};\n\n/**\n * @author zz85 / https://github.com/zz85 | https://www.lab4games.net/zz85/blog\n *\n * Edge Detection Shader using Sobel filter\n * Based on http://rastergrid.com/blog/2011/01/frei-chen-edge-detector\n *\n * aspect: vec2 of (1/width, 1/height)\n */\n\nTHREE.EdgeShaderDetect = {\n\n\tuniforms: {\n\n\t\t\"u_VertexIDs\": \t{ type: \"t\", value: null },\n\t\t\"u_DepthTex\": \t\t{ type: \"t\", value: null },\n\t\t\"u_RenderPassDepth\":{ type: \"t\", value: null },\n\t\t\"u_TexSize\": \t\t{ type: \"v2\", value: new THREE.Vector2( 512, 512 ) },\n\t\t\"u_Viewport\":\t\t{ type: \"v4\", value: new THREE.Vector4( 0, 0, 512, 512 ) },\n\t\t\"u_CreaseThresh\": \t{ type: \"v2\", value: new THREE.Vector2( 512, 512 ) },\n\t},\n\n\tvertexShader: [\n\t\t \"precision highp float;\",\n\t\t//This shader assumes a full screen quad is drawn in \n\t\t//normalized coordinates. \n\t\t//It will compute the texture offsets for 3x3 filter taps\n\t\t\"uniform vec2 u_TexSize;\",\n\t\t\"varying vec2 v_NW;\",\n\t\t\"varying vec2 v_NE;\",\n\t\t\"varying vec2 v_C;\",\n\t\t\"varying vec2 v_SE;\",\n\t\t\"varying vec2 v_SW;\",\n\t\t\"varying mat4 u_Proj;\",\n\t\t\"void main()\",\n\t\t\"{\",\n\t\t\t\"u_Proj = projectionMatrix;\",\n\t\t\t\"v_NW = uv + vec2(-1,1)*u_TexSize;\",\n\t\t\t\"v_NE = uv + vec2(1,1)*u_TexSize;\",\n\t\t\t\"v_C = uv;\",\n\t\t\t\"v_SW = uv + vec2(-1,-1)*u_TexSize;\",\n\t\t\t\"v_SE = uv + vec2(1,-1)*u_TexSize;\",\n\t\t\t\"gl_Position = projectionMatrix * modelViewMatrix * vec4( position, 1.0 );\",\n\t\t\t\n\t\t\"}\",\n\n\t].join( \"\\n\" ),\n\n\tfragmentShader: [\n\t\t \"precision highp float;\",\n\t\t\"uniform sampler2D u_VertexIDs;\",\n\t\t\"uniform sampler2D u_DepthTex;\",\n\t\t\"uniform sampler2D u_RenderPassDepth;\",\n\t\t\"uniform int u_ProjType;\", // ortho (0), perspective (1)\n\t\t\"uniform vec4 u_Viewport;\", // x, y, width, height\n\t\t\"uniform vec2 u_CreaseThresh;\",\n\t\t// x is cosine of normal crease angle, y is cosin of depth crease angle\n\t\t/*\n\t\tFor the depth edges we are going to unproject the depthTex and \n\t\tthe frag coords.\n\t\tProjection matrix is assumed to be of the form \n\t\tOrtho: \n\t\t[A, O, O, D,\n\t\t0, B, 0, E,\n\t\t0, 0, c, F,\n\t\t0, 0, 0, 1]\n\n\t\tPerspective:\n\t\t[A, 0, D, 0,\n\t\t0, B, E, 0,\n\t\t0, 0, C, F,\n\t\t0, 0, -1, 0]\n\t\tTODO: May want to split this into two separate shaders.\n\t\t*/\n\n\t\t//Texture coords from vertext shader. \n\t\t//It should be faster for the prefetches to precompute these in \n\t\t//the vertex shader. \n\n\t\t\"varying vec2 v_NW;\",\n\t\t\"varying vec2 v_NE;\",\n\t\t\"varying vec2 v_C;\",\n\t\t\"varying vec2 v_SW;\",\n\t\t\"varying vec2 v_SE;\",\n\t\t\"varying mat4 u_Proj;\",\n\t\t\n\t\t\"const float UnpackDownscale = 255. / 256.;\",\n\t\t\"const vec3 PackFactors = vec3( 256. * 256. * 256., 256. * 256.,  256. );\",\n\t\t\"vec4 UnpackFactors = UnpackDownscale / vec4( PackFactors, 1. );\",\n\t\t\n\t\t\"float unpackRGBAToDepth( const in vec4 v ) {\",\n\t\t\t\"return dot( v, UnpackFactors );\",\n\t\t\"}\",\n\t\t\n\t\t\n\t\t\"void main()\",\n\t\t\"{\",\n\t\t\t\"vec4 idnC = texture2D(u_VertexIDs, v_C);\",\n\t\t\t\"vec2 clampval;\",\n\t\t\t\"clampval.x = 1.0 / u_Viewport.z; clampval.y = 1.0 / u_Viewport.w;\",\n\t\t\t\"vec2 clampvalmax = vec2(1.0 - clampval.x, 1.0 - clampval.y);\",\n\t\t\t\"vec2 center =  clamp(v_C,  clampval, clampvalmax);\",\n\t\t\t\"vec2 northeast = clamp(v_NE, clampval, clampvalmax);\",\n\t\t\t\"vec2 northwest = clamp(v_NW, clampval, clampvalmax);\",\n\t\t\t\"vec2 southeast = clamp(v_SE, clampval, clampvalmax);\",\n\t\t\t\"vec2 southwest = clamp(v_SW, clampval, clampvalmax);\",\n\t\t\t//4 taps in X Pattern\n\t\t\t\"vec4 idnNE = texture2D(u_VertexIDs, northeast);\",\n\t\t\t\"vec4 idnNW = texture2D(u_VertexIDs, northwest);\",\n\t\t\t\"vec4 idnSE = texture2D(u_VertexIDs, southeast);\",\n\t\t\t\"vec4 idnSW = texture2D(u_VertexIDs, southwest);\",\n\t\t\t\n\t\t\t\n\t\t\t/*\"idnNE = idnNE*2.0-1.0;\",\n\t\t\t\"idnNW = idnNW*2.0-1.0;\",\n\t\t\t\"idnSE = idnSE*2.0-1.0;\",\n\t\t\t\"idnSW = idnSW*2.0-1.0;\",*/\n\t\t\t\n\t\t\t/*\"float dC = unpackRGBAToDepth(texture2D(u_DepthTex, center));\",\n\t\t\t\"float dNE = unpackRGBAToDepth(texture2D(u_DepthTex, northeast));\",\n\t\t\t\"float dNW = unpackRGBAToDepth(texture2D(u_DepthTex, northwest));\",\n\t\t\t\"float dSE = unpackRGBAToDepth(texture2D(u_DepthTex, southeast));\",\n\t\t\t\"float dSW = unpackRGBAToDepth(texture2D(u_DepthTex, southwest));\",*/\n\t\t\t\n\t\t\t\"float dC = texture2D(u_DepthTex, center).x;\",\n\t\t\t\"float dNE = texture2D(u_DepthTex, northeast).x;\",\n\t\t\t\"float dNW = texture2D(u_DepthTex, northwest).x;\",\n\t\t\t\"float dSE = texture2D(u_DepthTex, southeast).x;\",\n\t\t\t\"float dSW = texture2D(u_DepthTex, southwest).x;\",\n\t\t\t\n\t\t\t/*\"float dC =  idnC.w;\",\n\t\t\t\"float dNE = idnNE.w;\",\n\t\t\t\"float dNW = idnNW.w;\",\n\t\t\t\"float dSE = idnSE.w;\",\n\t\t\t\"float dSW = idnSW.w;\",*/\n\t\t\t\n\t\t\t\"float edge = 0.0;\",\n\t\t\t\"float objectEdge = 0.0;\",//step(0.5,abs(idnNE.x-idnSW.x) + abs(idnNW.x-idnSE.x));\",\n\t\t\t// 0 -> 1\n\t\t\t\"idnNE = normalize(idnNE);\",\n\t\t\t\"idnSW = normalize(idnSW);\",\n\t\t\t\"idnSE = normalize(idnSE);\",\n\t\t\t\"idnNW = normalize(idnNW);\",\n\t\t\t\"float N1 = dot(idnNE.xyz, idnSW.xyz);\",\n\t\t\t\"float N2 = dot(idnSE.xyz, idnNW.xyz);\",\n\t\t\t\"float normalEdge = float(min(abs(N1),abs(N2))<u_CreaseThresh.x);\",\n\t\t\t//Compute the angle of the 3D crease in the depths\n\t\t\t//TODO: The following calculations could be sped up by \n\t\t\t//procomputing things on the CPU.\n\n\t\t\t\"vec3 dVNE = vec3(0.0);\",\n\t\t\t\"vec3 dVNW = vec3(0.0);\",\n\t\t\t\"vec3 dVSE = vec3(0.0);\",\n\t\t\t\"vec3 dVSW = vec3(0.0);\",\n\n\t\t\t\"float depthEdge = 0.0;\",\n\t\t\t//Unproject the depths and build 3D points\n\t\t\t//TODO: these calculations could be replaced with frustum bounds\n\t\t\t\"float viewXScale = 2.0/u_Viewport.z;\",\n\t\t\t\"float viewYScale = 2.0/u_Viewport.w;\",\n\t\t\t\"float Ainv = 1.0/(u_Proj[0]).x;\",//\"float Ainv = 1.0/u_Proj[0][0];\",\n\t\t\t\"float Binv = 1.0/(u_Proj[1]).y;\",\n\n\t\t\t//For perspective\n\t\t\t\"float C = (u_Proj[2]).z;\",\n\t\t\t\"float D = (u_Proj[0]).z;\",\n\t\t\t\"float E = (u_Proj[1]).z;\",\n\t\t\t\"float F = (u_Proj[3]).z;\",\n\t\t\t\n\t\t\t//Perspective\n\n\t\t\t\n\t\t\t//Convert window coordinates to NDC\n\t\t\t\"float xwC = gl_FragCoord.x;\",\n\t\t\t\"float ywC = gl_FragCoord.y;\",\n\t\t\t\"float xndC = (xwC-u_Viewport.x)*viewXScale -1.0;\",\n\t\t\t\"float yndC = (ywC-u_Viewport.y)*viewYScale -1.0;\",\n\t\t\t\"float zndC = dC*2.0 - 1.0;\",\n\n\t\t\t//Convert NDC to Eye space\n\t\t\t\"float ZeC  = -F/(zndC + C);\",\n\t\t\t\"vec3 eC = vec3( -ZeC*(xndC + D)*Ainv, -ZeC*(yndC + E)*Binv, ZeC);\",\n\t\t\t//Convert Window coords to NDC\n\t\t\t\"vec4 xndOff =( vec4(xwC +1.0, xwC - 1.0, xwC + 1.0, xwC - 1.0)-vec4(u_Viewport.x))*viewXScale - vec4(1.0);\",\n\t\t\t\"vec4 yndOff =( vec4(ywC +1.0, ywC + 1.0, ywC - 1.0, ywC - 1.0)-vec4(u_Viewport.y))*viewYScale - vec4(1.0);\",\n\t\t\t\"vec4 zndOff = vec4(dNE, dNW, dSE, dSW)*2.0 - vec4(1.0);\",\n\t\t\t//Convert NDC to Eye \n\t\t\t\"vec4 zeOff = -F/(zndOff + C);\",\n\t\t\t\"vec4 xeOff = -zeOff*(xndOff + D)*Ainv;\",\n\t\t\t\"vec4 yeOff = -zeOff*(yndOff + E)*Binv;\",\n\t\t\t//Compute the 3D tagent vectors.\n\t\t\t\"dVNE = vec3(xeOff.x, yeOff.x, zeOff.x) - eC;\", \n\t\t\t\"dVNW = vec3(xeOff.y, yeOff.y, zeOff.y) - eC;\", \n\t\t\t\"dVSE = vec3(xeOff.z, yeOff.z, zeOff.z) - eC;\", \n\t\t\t\"dVSW = vec3(xeOff.w, yeOff.w, zeOff.w) - eC;\",\n\n\t\t\t\"float N3 = dot(normalize(dVNW), normalize(dVSE));\",\n\t\t\t\"float N4 = dot(normalize(dVNE), normalize(dVSW));\",\n\t\t\t\"depthEdge = float(min(abs(N3),abs(N4))<u_CreaseThresh.y);\",\n\t\t\t//TODO: Add a material edge based on the z channel.\n\t\t\t\"edge = objectEdge + normalEdge + depthEdge;\",\n\t\t\t//edgeObject and normalEdge emitted for debugging reasons.\n\t\t\t//\"float test = dot(N1, N2);\",\n\t\t\t\"vec4 plantColor = texture2D(u_RenderPassDepth, center);\",\n\t\t\t\"if(plantColor.x == 0.0 && plantColor.y == 0.0 && plantColor.z == 0.0)\",\n\t\t\t\"{\",\n\t\t\t\t\"gl_FragColor = vec4(0.0,0.0,0.0,1.0);\",\n\t\t\t\"}\",\n\t\t\t\"else\",\n\t\t\t\"{\",\n\t\t\t\t\"gl_FragColor = vec4(normalEdge,edge,depthEdge,1.0);\",\n\t\t\t\"}\",\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\"}\",\n\n\t].join( \"\\n\" )\n\n};\n\n/**\n * @author zz85 / https://github.com/zz85 | https://www.lab4games.net/zz85/blog\n *\n * Edge Detection Shader using Sobel filter\n * Based on http://rastergrid.com/blog/2011/01/frei-chen-edge-detector\n *\n * aspect: vec2 of (1/width, 1/height)\n */\n\nTHREE.EdgeShaderDraw = {\n\n\tuniforms: {\n\t\t\"tDiffuse\": { type: \"t\", value: null },\n\t\t\"u_SrcColor\": { type: \"t\", value: null },\n\t\t\"u_TexSize\": { type: \"v2\", value: new THREE.Vector2( 512, 512 ) },\n\t\t\"u_EdgeWidth\" : { type: \"i\", value: 1 },\n\t\t\"u_LineColor\" : { type: \"f\", value: 1 },\n\t},\n\n\tvertexShader: [\n\n\t\t\"attribute vec2 a_Vertex;\",\t\t\t\t\t\t\t\t\t// Need to check what this attribute is.\n\t\t\"uniform vec2 u_TexSize;\",\t\t\t\t\t\t\t\t\t\t\n\t\t\"varying vec2 v_ul;\",\n\t\t\"varying vec2 v_uc;\",\n\t\t\"varying vec2 v_ur;\",\n\t\t\"varying vec2 v_cl;\",\n\t\t\"varying vec2 v_cc;\",\n\t\t\"varying vec2 v_cr;\",\n\t\t\"varying vec2 v_ll;\",\n\t\t\"varying vec2 v_lc;\",\n\t\t\"varying vec2 v_lr;\",\n                \"void main()\",\n\t\t\"{\",\n                \t\"v_ul = uv + vec2(-1,1)*u_TexSize;\",\n\t\t\t\"v_uc = uv + vec2(0,1)*u_TexSize;\",\n\t\t\t\"v_ur = uv + vec2(1,1)*u_TexSize;\",\n\t\t\t\"v_cl = uv + vec2(-1,0)*u_TexSize;\",\n\t\t\t\"v_cc = uv;\",\n\t\t\t\"v_cr = uv + vec2(1,0)*u_TexSize;\",\n\t\t\t\"v_ll = uv + vec2(-1,-1)*u_TexSize;\",\n\t\t\t\"v_lc = uv + vec2(0,-1)*u_TexSize;\",\n\t\t\t\"v_lr = uv + vec2(1,-1)*u_TexSize;\",\n\t\t\t\"gl_Position = vec4(a_Vertex, 0, 1);\",\n\t\t\t\"gl_Position = projectionMatrix * modelViewMatrix * vec4( position, 1.0 );\",\n\t\t\"}\"\n\n\t].join( \"\\n\" ),\n\n\tfragmentShader: [\n\n\t\t\"#define SQRT_TWO 1.41421356237\",\n\t\t\"uniform sampler2D tDiffuse;\",\n\t\t\"uniform sampler2D u_SrcColor;\",\n\t\t\n\t\t\"varying vec2 v_ul;\",\n\t\t\"varying vec2 v_uc;\",\n\t\t\"varying vec2 v_ur;\",\n\t\t\"varying vec2 v_cl;\",\n\t\t\"varying vec2 v_cc;\",\n\t\t\"varying vec2 v_cr;\",\n\t\t\"varying vec2 v_ll;\",\n\t\t\"varying vec2 v_lc;\",\n\t\t\"varying vec2 v_lr;\",\n\n\t\t\"uniform int u_EdgeWidth;\",\n\t\t\"uniform float u_LineColor;\", // white (0), black (1)\n\n\t\t\"uniform vec2 u_TexSize;\",\n\t\t\n\t\t\"void DrawEdge(float len)\",\n\t\t\"{\",\n\t\t\t//\"float kernelLen = ceil(len / 2.0);\",\n\t\t\t\"const float kernelLen = 1.0;\",\n\t\t\t\"float nearestDist = 10000.0;\",\n\t\t\t\"for (float i = -kernelLen; i <= kernelLen ; ++i) {\",\n\t\t\t\t\"for (float j = -kernelLen ; j <= kernelLen ; ++j) {\",\n\t\t\t\t\t\t\n\t\t\t\t\t\"vec2 texW = v_cc + u_TexSize*vec2(i-1.0,j);\",\n\t\t\t\t\t\"vec2 texE = v_cc + u_TexSize*vec2(i+1.0,j);\",\n\t\t\t\t\t\"vec2 texN = v_cc + u_TexSize*vec2(i,j+1.0);\",\n\t\t\t\t\t\"vec2 texS = v_cc + u_TexSize*vec2(i,j-1.0);\",\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\"float edgeW  = texture2D(tDiffuse, texW).y;\",// Need to role back when object detection is loaded\n\t\t\t\t\t\"float edgeE  = texture2D(tDiffuse, texE).y;\",// Need to role back when object detection is loaded\n\t\t\t\t\t\"float edgeN  = texture2D(tDiffuse, texN).y;\",// Need to role back when object detection is loaded\n\t\t\t\t\t\"float edgeS  = texture2D(tDiffuse, texS).y;\",// Need to role back when object detection is loaded\n\t\t\t\t\t\n\t\t\t\t\t\"float onEdgeNWES = step(.5,(step(1.5, edgeN+edgeS)+step(1.5, edgeE+edgeW)));\",\n\t\t\t\t\t\"nearestDist = mix(nearestDist, min(nearestDist, length(vec2(i, j)) ), onEdgeNWES);\",\n\t\t\t\t\"}\",\n\t\t\t\"}\",\n\t\t\t\n\t\t\t\"float maxDist = len / SQRT_TWO;\", // When the length is l, the diagnal line is always sqrt(2) * l.\n\t\t\t\"float margin = maxDist * 0.5;\",\n\t\t\t\"float threshold = maxDist - margin;\",\n\t\t\t\t\n\t\t\t\"float alpha = 0.0;\",\n\t\t\t\"alpha = mix( 1.0 - (nearestDist - threshold) / margin, 1.0, step(nearestDist, threshold) );\",\n\t\t\t\"vec3 color = texture2D(u_SrcColor, v_cc).xyz;\",\n\t\t\t//\"gl_FragColor = vec4(vec3((1.0-alpha) * u_LineColor),1.0);\",\n\t\t\t//\"gl_FragColor = vec4(0.0,0.0,0.0, alpha * u_LineColor);\",\n\t\t\t\"if(alpha == 1.0)\",\n\t\t\t\t\"gl_FragColor = vec4(0.0,0.0,0.0, alpha * u_LineColor);\",\n\t\t\t\"else\",\n\t\t\t\t\"gl_FragColor = vec4(color, alpha * u_LineColor);\",\n\t\t\"}\",\n\n\t\t\"void main() {\",\n\t\t\t\"DrawEdge(float(u_EdgeWidth));\",\n\t\t\"}\",\n\n\t].join( \"\\n\" )\n\n};\n\n/**\n * @author alteredq / http://alteredqualia.com/\n *\n * Full-screen textured quad shader\n */\n\nTHREE.CopyShader = {\n\n\tuniforms: {\n\n\t\t\"tDiffuse\": { value: null },\n\t\t\"opacity\":  { value: 1.0 }\n\n\t},\n\n\tvertexShader: [\n\n\t\t\"varying vec2 vUv;\",\n\n\t\t\"void main() {\",\n\n\t\t\t\"vUv = uv;\",\n\t\t\t\"gl_Position = projectionMatrix * modelViewMatrix * vec4( position, 1.0 );\",\n\n\t\t\"}\"\n\n\t].join( \"\\n\" ),\n\n\tfragmentShader: [\n\n\t\t\"uniform float opacity;\",\n\n\t\t\"uniform sampler2D tDiffuse;\",\n\n\t\t\"varying vec2 vUv;\",\n\n\t\t\"void main() {\",\n\n\t\t\t\"vec4 texel = texture2D( tDiffuse, vUv );\",\n\t\t\t\"gl_FragColor = opacity * texel;\",\n\n\t\t\"}\"\n\n\t].join( \"\\n\" )\n\n};\n\n/**\n * @author alteredq / http://alteredqualia.com/\n */\n\nTHREE.EffectComposer = function ( renderer, renderTarget ) {\n\n\tthis.renderer = renderer;\n\n\tif ( renderTarget === undefined ) {\n\n\t\tvar parameters = {\n\t\t\tminFilter: THREE.LinearFilter,\n\t\t\tmagFilter: THREE.LinearFilter,\n\t\t\tformat: THREE.RGBAFormat,\n\t\t\tstencilBuffer: false\n\t\t};\n\t\tvar size = renderer.getSize();\n\t\trenderTarget = new THREE.WebGLRenderTarget( size.width, size.height, parameters );\n\n\t}\n\n\tthis.renderTarget1 = renderTarget;\n\tthis.renderTarget2 = renderTarget.clone();\n\n\tthis.writeBuffer = this.renderTarget1;\n\tthis.readBuffer = this.renderTarget2;\n\n\tthis.passes = [];\n\n\tif ( THREE.CopyShader === undefined )\n\t\tconsole.error( \"THREE.EffectComposer relies on THREE.CopyShader\" );\n\n\tthis.copyPass = new THREE.ShaderPass( THREE.CopyShader );\n\n};\n\nObject.assign( THREE.EffectComposer.prototype, {\n\n\tswapBuffers: function() {\n\n\t\tvar tmp = this.readBuffer;\n\t\tthis.readBuffer = this.writeBuffer;\n\t\tthis.writeBuffer = tmp;\n\n\t},\n\n\taddPass: function ( pass, disableClipping ) {\n\t\t\n\t\tif(disableClipping)\n\t\t\tpass.disableClipping = disableClipping;\n\t\tthis.passes.push( pass );\n\n\t\tvar size = this.renderer.getSize();\n\t\tpass.setSize( size.width, size.height );\n\n\t},\n\n\tinsertPass: function ( pass, index ) {\n\t\tthis.passes.splice( index, 0, pass );\n\t},\n\n\trender: function ( delta ) {\n\n\t\tvar maskActive = false;\n\n\t\tvar pass, i, il = this.passes.length;\n\n\t\tfor ( i = 0; i < il; i ++ ) {\n\n\t\t\tpass = this.passes[ i ];\n\t\t\t\n\t\t\tif ( pass.enabled === false ) continue;\n\t\t\tif(pass.disableClipping) {\n\t\t\t\tvar tNear = manager._camera.near;\n\t\t\t\tvar tFar = manager._camera.far;\n\t\t\t\tmanager._camera.near = 300;\n\t\t\t\tmanager._camera.far = 2000000;\n\t\t\t\tmanager._camera.updateProjectionMatrix();\n\t\t\t\tvar globalPlanes = this.renderer.clippingPlanes;\n\t\t\t\tthis.renderer.clippingPlanes = [];\n\t\t\t\tpass.render( this.renderer, this.writeBuffer, this.readBuffer, delta, maskActive );\n\t\t\t\tmanager._camera.near = tNear;\n\t\t\t\tmanager._camera.far = tFar;\n\t\t\t\tmanager._camera.updateProjectionMatrix();\n\t\t\t\tthis.renderer.clippin