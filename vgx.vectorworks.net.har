s._normalMaterial.blending = THREE.NoBlending;\n\n\tvar pars1 = { minFilter: THREE.LinearFilter, magFilter: THREE.LinearFilter, format: THREE.RGBAFormat };\n\t// RenderTarget for normal map.\n\tthis._normalRenderTarget  = new THREE.WebGLRenderTarget(canvas.width, canvas.height, pars1 );\n\tthis._normalRenderTarget.texture.generateMipmaps = false;\n\t\n\t//\n\tthis._effectSave.enabled = true;\n\tthis._effectFXAA.uniforms[ 'resolution' ].value.set( 1 / canvas.width, 1 / canvas.height );\n\t\n\t// Background scene. \n\tvar clearMask = new THREE.ClearMaskPass();\t\n\tvar effectCopy = new THREE.ShaderPass(THREE.CopyShader);\n\tvar renderModelMask = new THREE.MaskPass(manager._scene, manager._camera);\n\teffectCopy.renderToScreen = true;\n\t// Remove this if not producing good effect.\n\trenderer.autoClear = false;\n\t// Initialization of the post processing shader in THREE.js\n\tvar renderPass = new THREE.RenderPass( manager._scene, manager._camera );\n\trenderPass.clear = false;\n\t\n\tthis._effectComposer.renderTarget1.stencilBuffer = true;\n\tthis._effectComposer.renderTarget2.stencilBuffer = true;\n\tthis._effectComposer.addPass(  this._backgroundRenderPass,true );\n\tthis._effectComposer.addPass( renderPass );\n\tthis._effectComposer.addPass( renderModelMask);\n\tthis._effectComposer.addPass( this._effectSave );\n\tthis._effectComposer.addPass( clearMask);\n\tthis._effectComposer.addPass( this._effectFXAA );\n\tthis._effectComposer.addPass( effectCopy );\n\tthis._effectComposer.setSize( canvas.width, canvas.height );\n\trenderer.setViewport(0,0,window.innerWidth, window.innerHeight);\n}\n\n/***********************************************************\n// Bilateral filtering of the Ambient occlusion\n\tssaoPassBilateral = new THREE.ShaderPass( THREE.SSAOShaderBilateral );\n\tssaoPassBilateral.uniforms[ 'u_ScreenRes' ].value = new THREE.Vector2( depthRenderTarget.width, depthRenderTarget.height );\n\tssaoPassBilateral.uniforms[ 'u_InvProj' ].value = new THREE.Matrix4().getInverse(camera.projectionMatrix);\n\tssaoPassBilateral.uniforms[ 'u_UVBound' ].value = new THREE.Vector4(0,0,depthRenderTarget.width/depthRenderTarget.height,1);//\n\tssaoPassBilateral.uniforms[ 'u_NearFar' ].value = new THREE.Vector2( camera.near, camera.far);\n\tssaoPassBilateral.uniforms[ 'u_TanHalfFOV' ].value = Math.tan((camera.fov/2) * (Math.PI/180));\n\tssaoPassBilateral.uniforms[ 'u_DepthTex' ].value = depthRenderTarget.depthTexture;\n\tssaoPassBilateral.uniforms[ 'u_AOInput' ].value = new THREE.Vector2(aoSize * aoSizeWeight, (aoPercantage * aoPowerWeight * (aoSize/ AOSizeDefault)) );\n\tssaoPassBilateral.uniforms[ 'u_VertexIDs' ].value = null;//\n************************************************************/\n/*\n\tVWManager\n\tThe VW Manager class is created to manage the loading and modifications in the geometry. \n\tCreated By : \n*/\n\n\"use strict\";\nself.VWNormalRenderer = function(manager, renderer) {\n\tthis._effectComposer = new THREE.EffectComposer( renderer );\n\tthis._effectFXAA = new THREE.ShaderPass( THREE.FXAAShader );\n\tthis._bIsChromeiOS = mobileAndTabletcheck() && navigator.userAgent.match('CriOS');\n\tthis._backgroundRenderPass = new THREE.RenderPass( manager._backgroundScene, manager._camera );\n\tthis._bDoesAOPass = false;\n}\n\nVWNormalRenderer.prototype = new THREE.EventDispatcher();\n\nVWNormalRenderer.prototype.render = function() {\n\tvar self = this;\n\treturn function() {\n\t\t//if(self._bDoesAOPass)\n\t\tmanager.dynamicNearFar();\n\t\tself._effectComposer.render(); \n\t\tif(skyBox && !manager._backgroundScene.staticBackground)\n\t\t\tskyBox.position.copy(camera.position);\n\t}\n}\n\nVWNormalRenderer.prototype.windowResize = function() {\n\tvar self = this;\n\treturn function(){\n\t\t\n\t\tcamera.aspect = window.innerWidth / window.innerHeight;\n\t\tcamera.updateProjectionMatrix();\n\t\trenderer.setSize( window.innerWidth, window.innerHeight );\n\t\trenderer.setViewport(0,0,window.innerWidth, window.innerHeight);\n\t\trenderer.shadowMap.renderReverseSided = true;\n\t\t\n\t\t\n\t\tvar canvas = document.querySelectorAll('canvas')[1];\n\t\t\n\t\tself._effectFXAA.uniforms[ 'resolution' ].value.set(  1 / canvas.width, 1 / canvas.height);\n\n\t\tself._effectComposer.setSize( canvas.width, canvas.height );\n\t\trenderer.setViewport(0,0,window.innerWidth, window.innerHeight);\n\t\t\n\t}\n}\n\nVWNormalRenderer.prototype.init = function(manager,renderer) {\n\tvar canvas = document.querySelectorAll('canvas')[1];\n\tthis._effectFXAA.uniforms[ 'resolution' ].value.set(  1 / canvas.width, 1 / canvas.height );\n\t\n\t// Background scene. \n\tvar effectCopy = new THREE.ShaderPass(THREE.CopyShader);\n\teffectCopy.renderToScreen = true;\n\t\n\tvar renderPass = new THREE.RenderPass( manager._scene, manager._camera );\n\trenderPass.clear = false;\n\t\n\tthis._effectComposer.addPass( this._backgroundRenderPass,true );\n\tthis._effectComposer.addPass( renderPass );\n\tthis._effectComposer.addPass( this._effectFXAA );\n\tthis._effectComposer.addPass( effectCopy );\n\tthis._effectComposer.setSize( canvas.width, canvas.height );\n\trenderer.setViewport(0,0,window.innerWidth, window.innerHeight);\n}\n\n\n/*\n\tVWManager\n\tThe VW Manager class is created to manage the loading and modifications in the geometry.\n\tCreated By :\n*/\n\n\"use strict\";\nself.VWRenderAdaptor = function(manager, renderer) {\n\tthis._composerRenderer = new VWComposerRender(manager, renderer);\n\tthis._normalRenderer = new VWNormalRenderer(manager,renderer);\n\tthis._normalRenderer.init(manager,renderer);\n\tthis._rendererElement = document;\n\tthis._cameraMoving = false;\n\tthis._currentRenderer = 1; // 1 normal renderer, 2 composer renderer\n\t//if(renderer)\n\t//\tthis._rendererElement = renderer;\n\tvar self = this;\n\tvar touchStart = false;\n\tvar timer;\n\n\tfunction onTimeOut(event) {\n\t\tif(manager._modelLoadComplete && self._cameraMoving == false){\n\t\t\trenderer.sortObjects = true;\n\t\t\tself.render = self.setRender(self._composerRenderer);\n\t\t\tself.windowResize = self.setWindowResize(self._composerRenderer);\n\t\t\tself._currentRenderer = 2;\n\t\t\tif(controltype != 3)\n\t\t\t{\n\t\t\t\trenderer.animate(null);\n\t\t\t\tself.render();\n\t\t\t}\n\t\t\telse\n\t\t\t{\n\t\t\t\trenderer.animate(animate);\n\t\t\t}\n\t\t\t\t\n\t\t\t\n\t\t}\n\t}\n\n\tfunction onMouseStart(){\n\t\tcontrolsLOC.update(camera.getWorldDirection());\n\t}\n\n\tfunction onTouchChange() {\n\t\tcontrolsLOC.DrawOnRotate(camera.getWorldDirection());\n\t}\n\n\tfunction onCameraChange(event) {\n\t\tif(event.buttons == 0)\n\t\t\treturn;\n\t\telse if(event.which == 0)\n\t\t\treturn;\n\t\tif(timer)\n\t\t\tclearTimeout(timer);\n\t\trenderer.animate(animate);\n\t\ttimer = setTimeout(onTimeOut,1000);\n\t\tself.render = self.setRender(self._normalRenderer);\n\t\tself.windowResize = self.setWindowResize(self._normalRenderer);\n\t\tthis._currentRenderer = 1;\n\n\t\t// NOTE: This is here to hook in modifying the arrow within the Light Direction dialog. Should be eventually moved to LightOrientationControls.\n\t\tcontrolsLOC.DrawOnRotate(camera.getWorldDirection());\n\t}\n\n\tfunction onTouchStart(event) {\n\t\trenderer.sortObjects = false;\n\t\tif(timer)\n\t\t\tclearTimeout(timer);\n\t\trenderer.animate(animate);\n\t\tself.render = self.setRender(self._normalRenderer);\n\t\tself.windowResize = self.setWindowResize(self._normalRenderer);\n\t\tself._currentRenderer = 1;\n\t\tcontrolsLOC.update(camera.getWorldDirection());\n\t}\n\n\n\tfunction onTouchEnd(event) {\n\t\trenderer.animate(animate);\n\t\ttimer = setTimeout(onTimeOut,1000);\n\t}\n\n\tfunction onCameraWheel(event) {\n\n\t\tif(timer)\n\t\t\tclearTimeout(timer);\n\t\trenderer.sortObjects = false;\n\t\trenderer.animate(animate);\n\t\ttimer = setTimeout(onTimeOut,1000);\n\t\tself.render = self.setRender(self._normalRenderer);\n\t\tself.windowResize = self.setWindowResize(self._normalRenderer);\n\t\tthis._currentRenderer = 1;\n\t}\n\n\tfunction onKeyPress(event) {\n\t\tswitch ( event.keyCode ) {\n\n\t\t\tcase 38: /*up*/\n\t\t\tcase 87: /*W*/\n\t\t\tcase 37: /*left*/\n\t\t\tcase 65: /*A*/\n\t\t\tcase 40: /*down*/\n\t\t\tcase 83: /*S*/\n\t\t\tcase 39: /*right*/\n\t\t\tcase 68: /*D*/\n\t\t\tcase 82: /*R*/\n\t\t\tcase 70: /*F*/\n\t\t\tif(timer)\n\t\t\t\tclearTimeout(timer);\n\t\t\t\trenderer.animate(animate);\n\t\t\t\ttimer = setTimeout(onTimeOut,1000);\n\t\t\t\tself.render = self.setRender(self._normalRenderer);\n\t\t\t\tself.windowResize = self.setWindowResize(self._normalRenderer);\n\t\t\t\tthis._currentRenderer = 1;\n\t\t\tbreak;\n\t\t\tdefault:\n\t\t\treturn;\n\t\t}\n\n\t}\n\n\tthis.render = this.setRender(this._normalRenderer);\n\tthis.windowResize = this.setWindowResize(this._normalRenderer);\n\n\tthis._rendererElement.addEventListener( 'mousedown', onMouseStart, false);\n\tthis._rendererElement.addEventListener( 'mousemove', onCameraChange, false );\n\tthis._rendererElement.addEventListener( 'touchmove', onTouchChange, false );\n\tthis._rendererElement.addEventListener( 'touchstart', onTouchStart, false );\n\tthis._rendererElement.addEventListener( 'touchend', onTouchEnd, false );\n\n\tthis._rendererElement.addEventListener( 'mousewheel', onCameraWheel, false );\n\tthis._rendererElement.addEventListener( 'MozMousePixelScroll', onCameraWheel, false ); // firefox\n\twindow.addEventListener( 'keydown', onKeyPress, false );\n\n}\n\nVWRenderAdaptor.prototype = new THREE.EventDispatcher();\n\nVWRenderAdaptor.prototype.setRender = function(renderStack) {\n\treturn renderStack.render();\n}\n\nVWRenderAdaptor.prototype.setWindowResize = function(renderStack) {\n\treturn renderStack.windowResize(camera, renderer);\n}\n\n/*\n\tVWManager\n\tThe VW Manager class is created to manage the loading and modifications in the geometry.\n\tCreated By : Sriram\n*/\n\nVWManager = function(scene, backgroundScene, camera, config) {\n\tthis._scene = scene;\n\tthis._backgroundScene = backgroundScene;\tthis._camera = camera;\n\tthis._mergeGeometries = config?(config.mergeGeometries?config.mergeGeometries:false):false;\n\n\tthis._clipSimulation;\n\n\tthis._octreeList = [];\n\tthis._octreeList.push(new THREE.Octree({undeferred: false,depthMax: Infinity,objectsThreshold: 8,overlapPct: 0.15}));\n\tthis._modelInfo = {\n\t\tnumberOfObjects : 0,\n\t\tnumberOfTriangles : 0,\n\t\tnumberOfTextures : 0,\n\t\tnavigationMeshCreated : false,\n\t};\n\tthis._boundMin;\n\tthis._boundMax;\n\tthis._boundCenter = new THREE.Vector3();\n\tthis._buildStarted = false;\n\tthis._meshForNavigation = [];\n\tthis._boxGeometry = new THREE.Geometry();\n\tthis._organizedScene = {};\n\tthis._modelLoadComplete = false;\n\tthis._ccPlanes = [];\n\tthis._edgeInfo = {\n\t\tedgesOn : false,\n\t\tthickness : 1,\n\t\tcreaseAngle : 70\n\t};\n\tthis._ambientInfo = {\n\t\tambientOn : false,\n\t\tstrength : 50,\n\t\tsize : 24\n\t};\n\tthis._originalCamFOV = this._camera.fov;\n\tthis._originalCamNear = this._camera.near;\n\tthis._originalCamFar = this._camera.far;\n\n\tthis._vgx = new VGX(0.2);\n\tvar _loader = new VWModelLoader(this);\n\t_loader.init(2, Configuration.workerScriptUrl);\n\t_loader.addEventListener('errorProcessing',this.onErrorMessage.bind(this));\n\t_loader.addEventListener('objectAdded',this.onSuccessfulLoading.bind(this));\n\t_loader.addEventListener('modelLoadiongComplete',this.onModelLoadComplete.bind(this));\n\n\tthis._shadowLight;\n\tthis._defaultLight;\n\t\n\tthis._renderAdaptor = new VWRenderAdaptor(this, renderer);\n\tthis.sendToLoader = function(data) {\n\t\t_loader.loadModel(data);\n\t};\n};\n\nVWManager.prototype = new THREE.EventDispatcher();\n\n\nVWManager.prototype.dynamicNearFar = function() {\n\n\tif(!this._boundMax || !this._boundMin)\n\t\treturn;\n\tif(controltype == 3)\n\t\treturn;\n\tvar BBCenterDistance = this._camera.position.distanceTo(this._boundCenter);\n\tvar BBmaxDistance = this._boundMax.distanceTo(this._boundMin);\n\n\tif(BBCenterDistance <= BBmaxDistance/2){\n\t\tif(BBCenterDistance < 300)\t{\t\t\t// This is again a hack for the closer objects. But need to evalute why reducing the near directly to 1 starts rendering artifacts when object is near, When object is far from camera the artifacts are not visible now. The out put is not correct when camera goes very much close to the bounding box center.\n\t\t\tthis._camera.near = 10;\n\t\t}\n\t\telse\n\t\tthis._camera.near = 300;\n\t\tthis._camera.far = BBmaxDistance * 2 +  BBmaxDistance / 2;\n\t}\n\telse {\n\t\tthis._camera.near = Math.abs(BBCenterDistance - BBmaxDistance/2);\n\t\tthis._camera.far = Math.abs(BBCenterDistance + BBmaxDistance);\n\t}\n\tif(this._camera.far > 2000000)\n\t\tthis._camera.far = 2000000;\n\tthis._camera.updateProjectionMatrix();\n\tthis._originalCamNear = this._camera.near;\n\tthis._originalCamFar = this._camera.far;\n}\n\nVWManager.prototype.loadModel = function() {\n\n\t// The following progress bar callback should be coming from VWApp. Since this deals with the UI. But for now we will add this here.\n\tvar progressCallback = function(event) {\n\t\tvar widthStr = '100%';\n\t\tif (event.loaded < event.total)\n\t\t\twidthStr = event.loaded/event.total +'%';\n\n\t  setTimeout(function() {\n        $(\"#myBar\").css({width:widthStr});\n\t\t}, 10);\n\t};\n\n\tvar vgxFileName;\n\tvar readStandardVGX = false;\n\tvar search = window.location.search;\n\tif (search) { // for VCS, dropbox, and others\n        var queryString = search.substring(1);\n        var pairs = queryString.split('&');\n        for (var i = 0; i < pairs.length; ++i) {\n            var pair = pairs[i].split('=');\n            var name = pair[0];\n            var value = pair[1];\n            if (name === 'download_url' || value.includes('.vgx')) {\n                vgxFileName = decodeURIComponent(value);\n            } else if (name === 'readStandard') {\n                readStandardVGX = value === '1';\n            }\n        }\n    }\n\n    if (!vgxFileName) {\n        if (resources[\"#filename\"] !== undefined) { // local and temporary\n            vgxFileName = resources[\"#filename\"];\n        } else {\n            vgxFileName = \"./testFile.vgx\";\n        }\n    }\n\n\tthis.sendToLoader({\n\t\ttype: \"addModel\",\n\t\tfile : vgxFileName,\n\t\tprogressBarCallBack : progressCallback,\n\t\treadStandardVGX : readStandardVGX\n\t});\n}\n\n\nVWManager.prototype.onErrorMessage = function(event) {\n\tmessage = event.data?event.data:event.message;\n\tmessage = JSON.stringify(message);\n\tconsole.log(message);\n}\n\nVWManager.prototype.createNavigationMap = function(geometry,visible,transparent,name){\n\tgeometry.computeBoundingBox();\n\tvar box = geometry.boundingBox;\n\tvar max = box.max.clone();\n\tvar min = box.min.clone();\n\tmax.applyAxisAngle ( new THREE.Vector3(1.0,0.0,0.0), - Math.PI/2 );\n\tmax.applyAxisAngle ( new THREE.Vector3(0.0,1.0,0.0), Math.PI/2 );\n\tmin.applyAxisAngle ( new THREE.Vector3(1.0,0.0,0.0), - Math.PI/2 );\n\tmin.applyAxisAngle ( new THREE.Vector3(0.0,1.0,0.0), Math.PI/2 );\n\tif((Math.abs(max.x - min.x) < 2000) && (Math.abs(max.z - min.z) < 2000)) {\n\n\t\tvar boxGeometry = new THREE.BoxGeometry(max.x - min.x,max.y - min.y,max.z - min.z);\n\t\tboxGeometry.translate(min.x + (max.x - min.x)/2,min.y + (max.y - min.y)/2, min.z + (max.z - min.z)/2);\n\t\tvar mesh = new THREE.Mesh(boxGeometry);\n\t\tmesh.material.side = THREE.DoubleSide;\n\t\tmesh.material.transparent = transparent;\n\t\tmesh.name = name;\n\n\t\tthis._octreeList[0].add(mesh);\n\t\tthis._octreeList[0].update();\n\t\treturn -1;\n\t}\n\telse {\n\t\tgeometry.rotateX(- Math.PI/2);\n\t\tgeometry.rotateY(Math.PI/2);\n\t\tvar mesh = new THREE.Mesh(geometry);\n\t\tmesh.material.side = THREE.DoubleSide;\n\t\tmesh.material.transparent = transparent;\n\t\tmesh.name = name;\n\t\tvar octree = new THREE.Octree({undeferred: false,depthMax: Infinity,objectsThreshold: 8,overlapPct: 0.15});\n\t\toctree.name = name;\n\t\toctree.add(mesh);\n\t\toctree.update();\n\t\tthis._octreeList.push(octree);\n\t\treturn 0;\n\t}\n}\n\n\nVWManager.prototype.onSuccessfulLoading = function(event) {\n\t//console.log(event.data.message);\n}\n\nVWManager.prototype.onModelLoadComplete = function(event) {\n\tthis._modelLoadComplete = true;\n\tthis._renderAdaptor.render = this._renderAdaptor.setRender(this._renderAdaptor._composerRenderer);\n\tthis._renderAdaptor._composerRenderer._effectComposer.renderer.shadowMap.enabled = true;\n\tthis._renderAdaptor._normalRenderer._effectComposer.renderer.shadowMap.enabled = true;\n\n\tthis._clipSimulation = new CAPS.Simulation(this._backgroundScene, this._camera, this._renderAdaptor, this._boundMax, this._boundMin);\n\n\tvar triangleLimit = 1500000;\n\tif(mobileAndTabletcheck())\n\t\ttriangleLimit = 700000;\n\tif(this._modelInfo.numberOfTriangles > triangleLimit) {\n\t\tShowPopup(resources[\"#nav_mes_1\"])\n\t\toctCanBeBuild = false;\n\t\t$(\"#startupTutorial\").css({display:'none'});\n\t\treturn;\n\t}\n\n\toctCanBeBuild = true;\n\tthis.buildNavigationMap(100);\n    // show the tutorial to the user\n    DoTutorial();\n\treturn;\n}\n\nVWManager.prototype.addToNavMesh = function(mesh) {\n\tthis._meshForNavigation.push(mesh);\n\tif(this._modelLoadComplete ){\n\t\t//this._buildStarted = false;\n\t\tthis.buildNavigationMap(100);\n\t}\n}\n\nVWManager.prototype.buildNavigationMap = function(timer){\n\tif(!this._modelLoadComplete) {\n\t\toctCanBeBuild = false;\n\t\treturn;\n\t}\n\tif(this._buildStarted){\n\t\treturn;\n\t}\n\n\tthis._buildStarted = true;\n\tvar self = this;\n\tfunction getNextGeometryForNavMap() {\n\t\tfor(var i = 0 ; i < self._meshForNavigation.length ; ++i) {\n\t\t\tif(!self._meshForNavigation[i].navMeshCreated) {\n\t\t\t\tself._meshForNavigation[i].navMeshCreated = true;\n\t\t\t\treturn self._meshForNavigation[i];\n\t\t\t}\n\t\t}\n\t\t//alert(\"Nav Mesh Created. You can now start using the first person mode or immersive mode...\");\n\t\tself._modelInfo.navigationMeshCreated = true;\n\t\treturn undefined;\n\t}\n\t// timer will set for creating the octree.\n\t// Check the model info where the number of octree objects is to be created.\n\t// If the number is zero then only use the octree for navigation.\n\t// Prior to checking the model info check if octree is to be created or not.\n\n\tvar processGeometry = (function(){\n\t\treturn function(){\n\t\t\tvar node = getNextGeometryForNavMap();\n\t\t\tif(!node) {\n\t\t\t\tself._buildStarted = false;\n\t\t\t\treturn;\n\t\t\t}\n\t\t\tif(node.geometry && node.geometry instanceof THREE.BufferGeometry){\n\t\t\t\tif(node.geometry.attributes.position && node.geometry.attributes.position.count > 0){\n\t\t\t\t\tsetTimeout(function(){\n\t\t\t\t\t\tif (node.geometry.index != null){\n\t\t\t\t\t\t\tvar geometryActualConverted;\n\t\t\t\t\t\t\ttry{\n\t\t\t\t\t\t\t\tgeometryActualConverted = new THREE.Geometry().fromBufferGeometry(node.geometry);\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tcatch (error){\n\t\t\t\t\t\t\t\tnode.geometry.index.array = new Array(node.geometry.attributes.position.count);\n\t\t\t\t\t\t\t\tnode.geometry.index.count = node.geometry.attributes.position.count;\n\t\t\t\t\t\t\t\tnode.geometry.groups[0].count = node.geometry.attributes.position.count; // HACK!!! BE VERY CAREFUL HERE SINCE A GEOMETRY CAN HAVE MULTIPLE GROUPS.\n\t\t\t\t\t\t\t\tfor (var i = 0; i < node.geometry.index.array.length; i++)\n\t\t\t\t\t\t\t\t\tnode.geometry.index.array[i] = i;\n\t\t\t\t\t\t\t\tgeometryActualConverted = new THREE.Geometry().fromBufferGeometry(node.geometry);\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tgeometryActualConverted.mergeVertices();\n\t\t\t\t\t\t\tnode.geometry = new THREE.BufferGeometry().fromGeometry(geometryActualConverted);\n\t\t\t\t\t\t\tnode.receiveShadow = true;\n\t\t\t\t\t\t\tnode.castShadow = true;\n\t\t\t\t\t\t\tnode.material.needsUpdate = true;\n\t\t\t\t\t\t\tself.createNavigationMap(geometryActualConverted,node.visible,node.material.transparent, node.name, node.material.opacity);\n\t\t\t\t\t\t\tprocessGeometry();\n\t\t\t\t\t\t}\n\t\t\t\t\t},timer?timer:300);\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t})();\n\tprocessGeometry();\n}\n\nVWManager.prototype.addCuttingPlane = function(inCutPlane){\n\t\n\tif(isNaN(inCutPlane.position[0]) || isNaN(inCutPlane.position[1]) || isNaN(inCutPlane.position[2]) || isNaN(inCutPlane.direction[0]) || isNaN(inCutPlane.direction[1]) || isNaN(inCutPlane.direction[2]))\n\t\treturn;\n\tvar position = new THREE.Vector3(inCutPlane.position[0],inCutPlane.position[1],inCutPlane.position[2]);\n\t\n\tif(!this._boundMax)\n\t\tthis._boundMax = new THREE.Vector3().copy(position);\n\tif(!this._boundMin)\n\t\tthis._boundMin = new THREE.Vector3().copy(position);\n\t \n\t this._boundMax.x = (this._boundMax.x < position.x)?position.x:this._boundMax.x;\n\t this._boundMax.y = (this._boundMax.y < position.y)?position.y:this._boundMax.y;\n\t this._boundMax.z = (this._boundMax.z < position.z)?position.z:this._boundMax.z;\n\t this._boundMin.x = (this._boundMin.x > position.x)?position.x:this._boundMin.x;\n\t this._boundMin.y = (this._boundMin.y > position.y)?position.y:this._boundMin.y;\n\t this._boundMin.z = (this._boundMin.z > position.z)?position.z:this._boundMin.z;\n\n}\n\nVWManager.prototype.addAmbientOcclusionData = function(iAOData) {\n\tthis._ambientInfo.ambientOn = true;\n\tthis._renderAdaptor._composerRenderer.initAmbientOcclusionShader(this._camera);\n\tthis._renderAdaptor._normalRenderer._bDoesAOPass = true;\n\tif(iAOData.size){\n\t\tthis._ambientInfo.size = iAOData.size;\n\t}\n\tif(iAOData.strength) {\n\t\tthis._ambientInfo.strength = iAOData.strength;\n\t}\n\tthis._renderAdaptor._composerRenderer.updateSSAOShaderCode(this._ambientInfo);\n}\n\nVWManager.prototype.addEdgeShaderData = function(iESData) {\n\tthis._edgeInfo.edgesOn = true;\n\tthis._renderAdaptor._composerRenderer.initEdgeShader();\n\tif(iESData.thickness){\n\t\tthis._edgeInfo.thickness = iESData.thickness;\n\t}\n\tif(iESData.creaseAngle) {\n\t\tthis._edgeInfo.creaseAngle = iESData.creaseAngle;\n\t}\n\tthis._renderAdaptor._composerRenderer.updateEdgeShaderCode(this._edgeInfo);\n}\n\nVWManag